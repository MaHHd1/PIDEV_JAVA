<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="gui.MessageController">

    <top>
        <VBox spacing="8.0" style="-fx-background-color:#1f2937; -fx-padding:18;">
            <Button text="← Retour" onAction="#goBack" style="-fx-background-color: #374151; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" />
            <Label text="Admin - Gestion des messages"
                   style="-fx-text-fill:white; -fx-font-size:22; -fx-font-weight:bold;"/>
            <Label text="Créer, modifier et supprimer les messages"
                   style="-fx-text-fill:#d1d5db; -fx-font-size:13;"/>
        </VBox>
    </top>

    <center>
        <VBox spacing="18.0">
            <padding>
                <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
            </padding>
            <GridPane hgap="14.0" vgap="14.0">

                <Label text="ID Expéditeur :" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <TextField fx:id="tfExpediteurId" promptText="Ex: 1" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                <Label text="ID Destinataire :" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                <TextField fx:id="tfDestinataireId" promptText="Ex: 2" GridPane.columnIndex="3" GridPane.rowIndex="0"/>

                <Label text="Objet :" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <TextField fx:id="tfObjet" promptText="Objet du message" GridPane.columnIndex="1" GridPane.columnSpan="3" GridPane.rowIndex="1"/>

                <Label text="Contenu :" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <TextArea fx:id="taContenu" prefRowCount="6" wrapText="true"
                          GridPane.columnIndex="1" GridPane.columnSpan="3" GridPane.rowIndex="2"/>

                <Label text="Statut :" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                <ComboBox fx:id="cbStatut" prefWidth="180.0" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                <Label text="Priorité :" GridPane.columnIndex="2" GridPane.rowIndex="3"/>
                <ComboBox fx:id="cbPriorite" prefWidth="180.0" GridPane.columnIndex="3" GridPane.rowIndex="3"/>

                <Label text="Catégorie :" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                <ComboBox fx:id="cbCategorie" prefWidth="180.0" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                <Label text="Parent ID :" GridPane.columnIndex="2" GridPane.rowIndex="4"/>
                <TextField fx:id="tfParentId" promptText="Optionnel" GridPane.columnIndex="3" GridPane.rowIndex="4"/>

                <Label text="Pièce jointe URL :" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                <TextField fx:id="tfPieceJointeUrl" promptText="Optionnel"
                           GridPane.columnIndex="1" GridPane.columnSpan="3" GridPane.rowIndex="5"/>
            </GridPane>

            <HBox spacing="12.0">
                <Button text="Ajouter" onAction="#ajouterMessage"/>
                <Button text="Modifier" onAction="#modifierMessage"/>
                <Button text="Supprimer" onAction="#supprimerMessage"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>