<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.EventManagementController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label text="Gestion des Événements" style="-font-size: 24px; -fx-font-weight: bold;" />

    <GridPane hgap="10" vgap="10">
        <Label text="Titre:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <TextField fx:id="titreField" GridPane.columnIndex="1" GridPane.rowIndex="0" />

        <Label text="Lieu:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <TextField fx:id="lieuField" GridPane.columnIndex="1" GridPane.rowIndex="1" />

        <Label text="Type:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
        <TextField fx:id="typeField" GridPane.columnIndex="1" GridPane.rowIndex="2" />
    </GridPane>

    <HBox spacing="10" alignment="CENTER">
        <Button text="Ajouter" onAction="#handleAjouter" />
        <Button text="Vider" onAction="#handleVider" />
    </HBox>

    <TableView fx:id="eventTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colTitre" text="Titre" prefWidth="150" />
            <TableColumn fx:id="colLieu" text="Lieu" prefWidth="150" />
            <TableColumn fx:id="colType" text="Type" prefWidth="100" />
        </columns>
    </TableView>
</VBox>
