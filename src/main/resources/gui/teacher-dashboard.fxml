<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.TeacherDashboardController" styleClass="dashboard-shell teacher-shell">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="18.0" styleClass="topbar profile-topbar">
            <VBox spacing="4.0">
                <Label fx:id="welcomeLabel" styleClass="dashboard-title" text="Hello" />
                <Label fx:id="roleLabel" styleClass="dashboard-subtitle" text="Teacher dashboard" />
            </VBox>
            <HBox HBox.hgrow="ALWAYS" />
            <HBox alignment="CENTER_RIGHT" spacing="10.0" styleClass="profile-chip">
                <VBox alignment="CENTER_RIGHT" spacing="2.0">
                    <Label fx:id="currentUserNameLabel" styleClass="profile-name" text="Teacher User" />
                    <Label fx:id="currentUserRoleLabel" styleClass="profile-role" text="enseignant" />
                </VBox>
                <MenuButton fx:id="profileMenuButton" styleClass="profile-menu-button" text="TU">
                    <items>
                        <MenuItem onAction="#handleProfileLogout" text="Disconnect" />
                    </items>
                </MenuButton>
            </HBox>
        </HBox>
    </top>
    <center>
        <VBox spacing="18.0" styleClass="dashboard-content">
            <padding>
                <Insets bottom="22.0" left="22.0" right="22.0" top="22.0" />
            </padding>
            <VBox spacing="10.0" styleClass="hero-banner teacher-banner">
                <Label styleClass="eyebrow" text="Teacher Space" />
                <Label styleClass="hero-title small-hero" text="Stay on top of your teaching profile, workload, and course rhythm." wrapText="true" />
            </VBox>
            <HBox spacing="18.0" VBox.vgrow="ALWAYS">
                <VBox spacing="10.0" styleClass="panel-card" HBox.hgrow="ALWAYS">
                    <Label styleClass="panel-title" text="Profile Snapshot" />
                    <ListView fx:id="profileList" VBox.vgrow="ALWAYS" />
                </VBox>
                <VBox spacing="10.0" styleClass="panel-card side-panel" HBox.hgrow="ALWAYS">
                    <Label styleClass="panel-title" text="Teaching Focus" />
                    <ListView fx:id="teachingList" VBox.vgrow="ALWAYS" />
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>
