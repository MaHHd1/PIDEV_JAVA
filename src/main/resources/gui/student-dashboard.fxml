<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.StudentDashboardController" styleClass="dashboard-shell academic-shell student-shell">
    <left>
        <VBox spacing="16.0" styleClass="sidebar academic-sidebar">
            <padding>
                <Insets bottom="20.0" left="18.0" right="18.0" top="20.0" />
            </padding>
            <Label styleClass="sidebar-brand" text="Student Hub" />
            <Label styleClass="sidebar-copy" text="Manage your profile and account security." wrapText="true" />
            <Button maxWidth="1.7976931348623157E308" onAction="#showProfilePage" styleClass="sidebar-button" text="Profile" />
            <Button maxWidth="1.7976931348623157E308" onAction="#showChangePasswordPage" styleClass="sidebar-button" text="Change Password" />
            <VBox VBox.vgrow="ALWAYS" />
            <Label styleClass="sidebar-foot" text="Student workspace" wrapText="true" />
        </VBox>
    </left>
    <top>
        <HBox alignment="CENTER_LEFT" spacing="18.0" styleClass="topbar profile-topbar">
            <VBox spacing="4.0">
                <Label fx:id="welcomeLabel" styleClass="dashboard-title" text="Hello" />
                <Label fx:id="roleLabel" styleClass="dashboard-subtitle" text="Student dashboard" />
            </VBox>
            <HBox HBox.hgrow="ALWAYS" />
            <HBox alignment="CENTER_RIGHT" spacing="10.0" styleClass="profile-chip">
                <VBox alignment="CENTER_RIGHT" spacing="2.0">
                    <Label fx:id="currentUserNameLabel" styleClass="profile-name" text="Student User" />
                    <Label fx:id="currentUserRoleLabel" styleClass="profile-role" text="etudiant" />
                </VBox>
                <MenuButton fx:id="profileMenuButton" styleClass="profile-menu-button" text="SU">
                    <items>
                        <MenuItem onAction="#showProfilePage" text="Profile" />
                        <MenuItem onAction="#showChangePasswordPage" text="Change password" />
                        <MenuItem onAction="#handleProfileLogout" text="Disconnect" />
                    </items>
                </MenuButton>
            </HBox>
        </HBox>
    </top>
    <center>
        <StackPane styleClass="dashboard-content">
            <padding>
                <Insets bottom="22.0" left="22.0" right="22.0" top="22.0" />
            </padding>

            <VBox fx:id="profileSection" spacing="18.0">
                <HBox spacing="18.0">
                    <VBox spacing="10.0" styleClass="hero-banner academic-banner" HBox.hgrow="ALWAYS">
                        <Label styleClass="eyebrow" text="Student Space" />
                        <Label styleClass="hero-title small-hero" text="Your academic profile and focus areas in one clear view." wrapText="true" />
                    </VBox>
                </HBox>
                <HBox spacing="18.0" VBox.vgrow="ALWAYS">
                    <VBox spacing="10.0" styleClass="panel-card" HBox.hgrow="ALWAYS">
                        <Label styleClass="panel-title" text="Profile Snapshot" />
                        <ListView fx:id="profileList" VBox.vgrow="ALWAYS" />
                    </VBox>
                    <VBox spacing="10.0" styleClass="panel-card side-panel" HBox.hgrow="ALWAYS">
                        <Label styleClass="panel-title" text="Focus List" />
                        <ListView fx:id="focusList" VBox.vgrow="ALWAYS" />
                    </VBox>
                </HBox>
            </VBox>

            <VBox fx:id="changePasswordSection" managed="false" spacing="18.0" visible="false">
                <HBox spacing="18.0">
                    <VBox spacing="10.0" styleClass="hero-banner academic-banner" HBox.hgrow="ALWAYS">
                        <Label styleClass="eyebrow" text="Security" />
                        <Label styleClass="hero-title small-hero" text="Update your account password." wrapText="true" />
                    </VBox>
                </HBox>
                <VBox maxWidth="520.0" spacing="14.0" styleClass="panel-card">
                    <Label styleClass="panel-title" text="Change Password" />
                    <PasswordField fx:id="currentPasswordField" promptText="Current password" styleClass="input-field" />
                    <PasswordField fx:id="newPasswordField" promptText="New password" styleClass="input-field" />
                    <PasswordField fx:id="confirmPasswordField" promptText="Confirm new password" styleClass="input-field" />
                    <Button maxWidth="1.7976931348623157E308" onAction="#handleChangePassword" styleClass="primary-button" text="Update password" />
                    <Label fx:id="changePasswordFeedbackLabel" styleClass="status-label" wrapText="true" />
                </VBox>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
