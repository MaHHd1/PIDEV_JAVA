<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.media.MediaView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.StudentDashboardController" styleClass="dashboard-shell student-shell">
    <left>
        <VBox spacing="16.0" styleClass="sidebar">
            <padding>
                <Insets bottom="20.0" left="18.0" right="18.0" top="20.0" />
            </padding>
            <Label styleClass="sidebar-brand" text="Student Hub" />
            <Label styleClass="sidebar-copy" text="Suivi de vos cours, contenus et inscriptions." wrapText="true" />
            <Button maxWidth="1.7976931348623157E308" onAction="#showOverviewPage" styleClass="sidebar-button" text="Vue d'ensemble" />
            <Button maxWidth="1.7976931348623157E308" onAction="#showMyCoursesPage" styleClass="sidebar-button" text="Mes cours" />
            <Button maxWidth="1.7976931348623157E308" onAction="#showAllCoursesPage" styleClass="sidebar-button" text="Tous les cours" />
            <Button maxWidth="1.7976931348623157E308" onAction="#openQuizHub"
                    styleClass="sidebar-button" text="🎯  Quiz"/>
            <VBox VBox.vgrow="ALWAYS" />
            <Label styleClass="sidebar-foot" text="Parcours etudiant personalise" wrapText="true" />
        </VBox>
    </left>
    <top>
        <HBox alignment="CENTER_LEFT" spacing="18.0" styleClass="topbar profile-topbar">
            <VBox spacing="4.0">
                <Label fx:id="sectionTitleLabel" styleClass="dashboard-title" text="Espace etudiant" />
                <Label fx:id="sectionSubtitleLabel" styleClass="dashboard-subtitle" text="Consultez vos cours, explorez le catalogue et accedez aux contenus de formation." />
            </VBox>
            <HBox HBox.hgrow="ALWAYS" />
            <HBox alignment="CENTER_RIGHT" spacing="10.0" styleClass="profile-chip">
                <VBox alignment="CENTER_RIGHT" spacing="2.0">
                    <Label fx:id="currentUserNameLabel" styleClass="profile-name" text="Student User" />
                    <Label fx:id="currentUserRoleLabel" styleClass="profile-role" text="etudiant" />
                </VBox>
                <MenuButton fx:id="profileMenuButton" styleClass="profile-menu-button" text="SU">
                    <items>
                        <MenuItem onAction="#handleProfileLogout" text="Disconnect" />
                    </items>
                </MenuButton>
            </HBox>
        </HBox>
    </top>
    <center>
        <StackPane styleClass="dashboard-content">
            <padding>
                <Insets bottom="22.0" left="22.0" right="22.0" top="22.0" />
            </padding>

            <VBox fx:id="overviewSection" spacing="18.0">
                <VBox spacing="10.0" styleClass="hero-banner student-banner">
                    <Label styleClass="eyebrow" text="Pilotage etudiant" />
                    <Label fx:id="welcomeLabel" styleClass="hero-title small-hero" text="Bienvenue" wrapText="true" />
                    <Label fx:id="roleLabel" styleClass="hero-copy" text="Retrouvez vos cours, vos contenus et les nouvelles inscriptions disponibles." wrapText="true" />
                </VBox>
                <HBox spacing="14.0">
                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                        <Label styleClass="stat-title" text="Cours inscrits" />
                        <Label fx:id="enrolledCoursesCountLabel" styleClass="stat-value" text="0" />
                    </VBox>
                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                        <Label styleClass="stat-title" text="Cours disponibles" />
                        <Label fx:id="availableCoursesCountLabel" styleClass="stat-value" text="0" />
                    </VBox>
                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                        <Label styleClass="stat-title" text="Contenus accessibles" />
                        <Label fx:id="completedContentsCountLabel" styleClass="stat-value" text="0" />
                    </VBox>
                </HBox>
                <HBox spacing="18.0" VBox.vgrow="ALWAYS">
                    <VBox spacing="10.0" styleClass="panel-card" HBox.hgrow="ALWAYS">
                        <Label styleClass="panel-title" text="Profil etudiant" />
                        <TableView fx:id="profileTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="profileFieldColumn" prefWidth="200.0" text="Champ" />
                                <TableColumn fx:id="profileValueColumn" prefWidth="360.0" text="Valeur" />
                            </columns>
                        </TableView>
                    </VBox>
                    <VBox spacing="10.0" styleClass="panel-card side-panel" HBox.hgrow="ALWAYS">
                        <Label styleClass="panel-title" text="Priorites" />
                        <TableView fx:id="focusTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="focusTitleColumn" prefWidth="180.0" text="Sujet" />
                                <TableColumn fx:id="focusDescriptionColumn" prefWidth="300.0" text="Detail" />
                            </columns>
                        </TableView>
                    </VBox>
                </HBox>
            </VBox>

            <VBox fx:id="myCoursesSection" managed="false" spacing="18.0" visible="false">
                <HBox spacing="18.0">
                    <VBox spacing="10.0" styleClass="hero-banner student-banner" HBox.hgrow="ALWAYS">
                        <Label styleClass="eyebrow" text="Mes cours" />
                        <Label styleClass="hero-title small-hero" text="Retrouvez vos cours deja inscrits et accedez rapidement a leurs contenus." wrapText="true" />
                        <Label fx:id="myCoursesContextLabel" styleClass="hero-copy" text="Parcours etudiant" wrapText="true" />
                    </VBox>
                    <VBox alignment="CENTER_RIGHT" spacing="10.0">
                        <Button onAction="#showAllCoursesPage" styleClass="primary-button compact-button" text="Explorer le catalogue" />
                        <Label fx:id="myCoursesMessageLabel" styleClass="status-label neutral-status" text="" wrapText="true" />
                    </VBox>
                </HBox>
                <HBox spacing="18.0" VBox.vgrow="ALWAYS">
                    <VBox spacing="12.0" styleClass="panel-card modules-list-panel" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                        <Label styleClass="panel-title" text="Cours inscrits" />
                        <TableView fx:id="myCoursesTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="myCourseCodeColumn" prefWidth="120.0" text="Code" />
                                <TableColumn fx:id="myCourseTitleColumn" prefWidth="230.0" text="Titre" />
                                <TableColumn fx:id="myCourseModuleColumn" prefWidth="170.0" text="Module" />
                                <TableColumn fx:id="myCourseLevelColumn" prefWidth="110.0" text="Niveau" />
                                <TableColumn fx:id="myCourseStatusColumn" prefWidth="110.0" text="Statut" />
                                <TableColumn fx:id="myCourseContentsColumn" prefWidth="110.0" text="Contenus" />
                                <TableColumn fx:id="myCourseActionsColumn" prefWidth="120.0" text="Actions" />
                            </columns>
                        </TableView>
                    </VBox>
                    <VBox fx:id="myCourseDetailsPanel" managed="false" spacing="14.0" styleClass="panel-card modules-detail-panel" visible="false">
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Label styleClass="panel-title" text="Fiche du cours" />
                            <HBox HBox.hgrow="ALWAYS" />
                            <Button onAction="#closeMyCourseDetails" styleClass="detail-close-button" text="X" />
                        </HBox>
                        <VBox spacing="12.0" styleClass="detail-hero-card">
                            <Label fx:id="myCourseDetailHeroTitleLabel" styleClass="detail-hero-title" text="Aucun cours selectionne" wrapText="true" />
                            <Label fx:id="myCourseDetailHeroMetaLabel" styleClass="detail-hero-meta" text="La fiche detaillee apparaitra ici apres selection dans la liste." wrapText="true" />
                        </VBox>
                        <GridPane hgap="12.0" vgap="10.0">
                            <Label styleClass="detail-key" text="Code" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                            <Label fx:id="myCourseDetailCodeLabel" styleClass="detail-value detail-multiline wide-detail" text="-" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                            <Label styleClass="detail-key" text="Titre" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                            <Label fx:id="myCourseDetailTitleLabel" styleClass="detail-value detail-multiline wide-detail" text="-" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                            <Label styleClass="detail-key" text="Module" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                            <Label fx:id="myCourseDetailModuleLabel" styleClass="detail-value detail-multiline wide-detail" text="-" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                            <Label styleClass="detail-key" text="Description" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                            <Label fx:id="myCourseDetailDescriptionLabel" styleClass="detail-value detail-multiline wide-detail" text="-" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                            <Label styleClass="detail-key" text="Niveau" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                            <Label fx:id="myCourseDetailLevelLabel" styleClass="detail-value detail-multiline wide-detail" text="-" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                            <Label styleClass="detail-key" text="Credits" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                            <Label fx:id="myCourseDetailCreditsLabel" styleClass="detail-value detail-multiline wide-detail" text="-" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                            <Label styleClass="detail-key" text="Langue" GridPane.columnIndex="0" GridPane.rowIndex="6" />
                            <Label fx:id="myCourseDetailLanguageLabel" styleClass="detail-value detail-multiline wide-detail" text="-" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="6" />
                            <Label styleClass="detail-key" text="Dates" GridPane.columnIndex="0" GridPane.rowIndex="7" />
                            <Label fx:id="myCourseDetailDatesLabel" styleClass="detail-value detail-multiline wide-detail" text="-" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="7" />
                            <Label styleClass="detail-key" text="Statut" GridPane.columnIndex="0" GridPane.rowIndex="8" />
                            <Label fx:id="myCourseDetailStatusLabel" styleClass="detail-value detail-multiline wide-detail" text="-" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="8" />
                            <Label styleClass="detail-key" text="Contenus" GridPane.columnIndex="0" GridPane.rowIndex="9" />
                            <Label fx:id="myCourseDetailContentsLabel" styleClass="detail-value detail-multiline wide-detail" text="-" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="9" />
                            <Label styleClass="detail-key" text="Image" GridPane.columnIndex="0" GridPane.rowIndex="10" />
                            <Label fx:id="myCourseDetailImageLabel" styleClass="detail-value detail-multiline wide-detail" text="-" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="10" />
                            <Label styleClass="detail-key" text="Prerequis" GridPane.columnIndex="0" GridPane.rowIndex="11" />
                            <Label fx:id="myCourseDetailPrerequisLabel" styleClass="detail-value detail-multiline wide-detail" text="-" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="11" />
                        </GridPane>
                        <Button onAction="#showContenusForSelectedMyCourse" styleClass="primary-button compact-button" text="Consulter les contenus" />
                    </VBox>
                </HBox>
            </VBox>

            <VBox fx:id="allCoursesSection" managed="false" spacing="18.0" visible="false">
                <HBox spacing="18.0">
                    <VBox spacing="10.0" styleClass="hero-banner admin-stats-banner" HBox.hgrow="ALWAYS">
                        <Label styleClass="eyebrow" text="Tous les cours" />
                        <Label styleClass="hero-title small-hero" text="Explorez les cours non encore inscrits et rejoignez le parcours qui vous convient." wrapText="true" />
                        <Label fx:id="allCoursesContextLabel" styleClass="hero-copy" text="Catalogue disponible" wrapText="true" />
                    </VBox>
                    <VBox alignment="CENTER_RIGHT" spacing="10.0">
                        <Button onAction="#showMyCoursesPage" styleClass="secondary-button compact-button" text="Retour mes cours" />
                        <Label fx:id="allCoursesMessageLabel" styleClass="status-label neutral-status" text="" wrapText="true" />
                    </VBox>
                </HBox>
                <HBox spacing="18.0" VBox.vgrow="ALWAYS">
                    <VBox spacing="12.0" styleClass="panel-card modules-list-panel" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                        <Label styleClass="panel-title" text="Catalogue de cours" />
                        <TableView fx:id="allCoursesTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="allCourseCodeColumn" prefWidth="120.0" text="Code" />
                                <TableColumn fx:id="allCourseTitleColumn" prefWidth="230.0" text="Titre" />
                                <TableColumn fx:id="allCourseModuleColumn" prefWidth="170.0" text="Module" />
                                <TableColumn fx:id="allCourseLevelColumn" prefWidth="110.0" text="Niveau" />
                                <TableColumn fx:id="allCourseStatusColumn" prefWidth="110.0" text="Statut" />
                                <TableColumn fx:id="allCourseContentsColumn" prefWidth="110.0" text="Contenus" />
                                <TableColumn fx:id="allCourseActionsColumn" prefWidth="140.0" text="Actions" />
                            </columns>
                        </TableView>
                    </VBox>
                    <VBox fx:id="allCourseDetailsPanel" managed="false" spacing="14.0" styleClass="panel-card modules-detail-panel" visible="false">
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Label styleClass="panel-title" text="Fiche du cours" />
                            <HBox HBox.hgrow="ALWAYS" />
                            <Button onAction="#closeAllCourseDetails" styleClass="detail-close-button" text="X" />
                        </HBox>
                        <VBox spacing="12.0" styleClass="detail-hero-card">
                            <Label fx:id="allCourseDetailHeroTitleLabel" styleClass="detail-hero-title" text="Aucun cours selectionne" wrapText="true" />
                            <Label fx:id="allCourseDetailHeroMetaLabel" styleClass="detail-hero-meta" text="La fiche detaillee apparaitra ici apres selection dans la liste." wrapText="true" />
                        </VBox>
                        <GridPane hgap="12.0" vgap="10.0">
                            <Label styleClass="detail-key" text="Code" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                            <Label fx:id="allCourseDetailCodeLabel" styleClass="detail-value detail-multiline wide-detail" text="-" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                            <Label styleClass="detail-key" text="Titre" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                            <Label fx:id="allCourseDetailTitleLabel" styleClass="detail-value detail-multiline wide-detail" text="-" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                            <Label styleClass="detail-key" text="Module" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                            <Label fx:id="allCourseDetailModuleLabel" styleClass="detail-value detail-multiline wide-detail" text="-" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                            <Label styleClass="detail-key" text="Description" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                            <Label fx:id="allCourseDetailDescriptionLabel" styleClass="detail-value detail-multiline wide-detail" text="-" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                            <Label styleClass="detail-key" text="Niveau" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                            <Label fx:id="allCourseDetailLevelLabel" styleClass="detail-value detail-multiline wide-detail" text="-" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                            <Label styleClass="detail-key" text="Credits" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                            <Label fx:id="allCourseDetailCreditsLabel" styleClass="detail-value detail-multiline wide-detail" text="-" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                            <Label styleClass="detail-key" text="Langue" GridPane.columnIndex="0" GridPane.rowIndex="6" />
                            <Label fx:id="allCourseDetailLanguageLabel" styleClass="detail-value detail-multiline wide-detail" text="-" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="6" />
                            <Label styleClass="detail-key" text="Dates" GridPane.columnIndex="0" GridPane.rowIndex="7" />
                            <Label fx:id="allCourseDetailDatesLabel" styleClass="detail-value detail-multiline wide-detail" text="-" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="7" />
                            <Label styleClass="detail-key" text="Statut" GridPane.columnIndex="0" GridPane.rowIndex="8" />
                            <Label fx:id="allCourseDetailStatusLabel" styleClass="detail-value detail-multiline wide-detail" text="-" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="8" />
                            <Label styleClass="detail-key" text="Contenus" GridPane.columnIndex="0" GridPane.rowIndex="9" />
                            <Label fx:id="allCourseDetailContentsLabel" styleClass="detail-value detail-multiline wide-detail" text="-" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="9" />
                            <Label styleClass="detail-key" text="Image" GridPane.columnIndex="0" GridPane.rowIndex="10" />
                            <Label fx:id="allCourseDetailImageLabel" styleClass="detail-value detail-multiline wide-detail" text="-" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="10" />
                            <Label styleClass="detail-key" text="Prerequis" GridPane.columnIndex="0" GridPane.rowIndex="11" />
                            <Label fx:id="allCourseDetailPrerequisLabel" styleClass="detail-value detail-multiline wide-detail" text="-" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="11" />
                        </GridPane>
                        <Button onAction="#enrollSelectedCourse" styleClass="primary-button compact-button" text="S'inscrire a ce cours" />
                    </VBox>
                </HBox>
            </VBox>

            <VBox fx:id="contenusSection" managed="false" spacing="18.0" visible="false">
                <HBox spacing="18.0">
                    <VBox spacing="10.0" styleClass="hero-banner student-banner" HBox.hgrow="ALWAYS">
                        <Label styleClass="eyebrow" text="Contenus du cours" />
                        <Label fx:id="currentCoursTitleLabel" styleClass="hero-title small-hero" text="Contenus du cours" wrapText="true" />
                        <Label fx:id="currentCoursSubtitleLabel" styleClass="hero-copy" text="Cours selectionne" wrapText="true" />
                    </VBox>
                    <VBox alignment="CENTER_RIGHT" spacing="10.0">
                        <Button onAction="#backToMyCoursesFromContenus" styleClass="secondary-button compact-button" text="Retour mes cours" />
                        <Label fx:id="contenusMessageLabel" styleClass="status-label neutral-status" text="" wrapText="true" />
                    </VBox>
                </HBox>
                <VBox spacing="18.0" VBox.vgrow="ALWAYS">
                    <VBox spacing="12.0" styleClass="panel-card modules-list-panel,student-outline-panel" VBox.vgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <VBox spacing="3.0">
                                <Label styleClass="panel-title" text="Parcours du cours" />
                                <Label styleClass="student-outline-copy" text="Choisissez un chapitre ou une ressource pour l'ouvrir dans la zone de consultation." wrapText="true" />
                            </VBox>
                            <HBox HBox.hgrow="ALWAYS" />
                            <Label fx:id="contenuCountLabel" styleClass="dashboard-subsection" text="0 contenu" />
                        </HBox>
                        <ScrollPane fitToWidth="true" styleClass="form-scroll-pane" VBox.vgrow="ALWAYS">
                            <content>
                                <VBox fx:id="contenuCardsContainer" spacing="14.0" />
                            </content>
                        </ScrollPane>
                    </VBox>
                    <VBox fx:id="contenuDetailsPanel" managed="false" spacing="16.0" styleClass="panel-card,student-viewer-panel" visible="false">
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Label fx:id="contenuViewerSectionLabel" styleClass="panel-title" text="Consultation" />
                            <HBox HBox.hgrow="ALWAYS" />
                            <Label fx:id="contenuViewerInfoLabel" styleClass="student-viewer-meta" text="-" wrapText="true" />
                        </HBox>
                        <VBox spacing="12.0" styleClass="detail-hero-card,student-viewer-header">
                            <Label fx:id="contenuHeroTitleLabel" styleClass="detail-hero-title" text="Selectionnez une ressource" wrapText="true" />
                            <Label fx:id="contenuHeroMetaLabel" styleClass="detail-hero-meta" text="Choisissez un contenu ci-dessous pour le consulter." wrapText="true" />
                        </VBox>
                        <Label fx:id="contenuViewerDescriptionLabel" styleClass="dashboard-subsection" text="Le contenu selectionne s'affiche directement sous son titre." wrapText="true" />
                        <VBox fx:id="contenuTextPanel" managed="false" spacing="10.0" styleClass="student-text-panel" visible="false">
                            <Label styleClass="student-resource-label" text="Lecture" />
                            <Label fx:id="contenuTextBodyLabel" styleClass="student-text-body" text="" wrapText="true" />
                        </VBox>
                        <StackPane fx:id="contenuMediaContainer" managed="false" prefHeight="320.0" styleClass="student-viewer-surface" visible="false">
                            <MediaView fx:id="contenuMediaView" fitHeight="300.0" fitWidth="760.0" preserveRatio="true" visible="false" />
                            <Label fx:id="contenuMediaPlaceholderLabel" styleClass="student-viewer-placeholder" text="Apercu du contenu" wrapText="true" />
                        </StackPane>
                        <VBox fx:id="contenuResourcePanel" managed="false" spacing="12.0" styleClass="student-resource-panel" visible="false">
                            <Label styleClass="student-resource-label" text="Acces au support" />
                            <Label fx:id="contenuViewerLinkLabel" styleClass="detail-value detail-multiline wide-detail student-resource-link" text="-" wrapText="true" />
                            <HBox spacing="10.0">
                                <Button fx:id="contenuPrimaryActionButton" managed="false" onAction="#handleContenuPrimaryAction" styleClass="primary-button compact-button" text="Ouvrir le support" visible="false" />
                                <Button fx:id="contenuSecondaryActionButton" managed="false" onAction="#handleContenuSecondaryAction" styleClass="secondary-button compact-button" text="Telecharger" visible="false" />
                            </HBox>
                        </VBox>
                    </VBox>
                </VBox>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
