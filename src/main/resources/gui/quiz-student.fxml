<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="gui.QuizController"
            styleClass="dashboard-shell student-shell">

    <!-- ═══════════════════════════════════════════════════════
         SIDEBAR
    ═══════════════════════════════════════════════════════ -->
    <left>
        <VBox spacing="16.0" styleClass="sidebar">
            <padding><Insets bottom="20.0" left="18.0" right="18.0" top="20.0"/></padding>
            <Label styleClass="sidebar-brand" text="Quiz Hub"/>
            <Label styleClass="sidebar-copy"
                   text="Testez vos connaissances et suivez vos résultats."
                   wrapText="true"/>
            <Button maxWidth="1.7976931348623157E308"
                    onAction="#showQuizListPage"
                    styleClass="sidebar-button" text="📋  Quiz disponibles"/>
            <Button maxWidth="1.7976931348623157E308"
                    onAction="#showMyResultsPage"
                    styleClass="sidebar-button" text="🏆  Mes résultats"/>
            <VBox VBox.vgrow="ALWAYS"/>
            <Label styleClass="sidebar-foot"
                   text="Évaluations en ligne · Campus Access" wrapText="true"/>
        </VBox>
    </left>

    <!-- ═══════════════════════════════════════════════════════
         TOPBAR
    ═══════════════════════════════════════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="18.0" styleClass="topbar profile-topbar">
            <VBox spacing="4.0">
                <Label fx:id="sectionTitleLabel" styleClass="dashboard-title" text="Espace Quiz"/>
                <Label fx:id="sectionSubtitleLabel" styleClass="dashboard-subtitle"
                       text="Choisissez un quiz et répondez aux questions."/>
            </VBox>
            <HBox HBox.hgrow="ALWAYS"/>
            <HBox alignment="CENTER_RIGHT" spacing="10.0" styleClass="profile-chip">
                <VBox alignment="CENTER_RIGHT" spacing="2.0">
                    <Label fx:id="currentUserNameLabel" styleClass="profile-name" text="Étudiant"/>
                    <Label fx:id="currentUserRoleLabel" styleClass="profile-role" text="etudiant"/>
                </VBox>
                <MenuButton fx:id="profileMenuButton" styleClass="profile-menu-button" text="EU">
                    <items>
                        <MenuItem onAction="#handleLogout" text="Déconnexion"/>
                    </items>
                </MenuButton>
            </HBox>
        </HBox>
    </top>

    <!-- ═══════════════════════════════════════════════════════
         CENTRE
    ═══════════════════════════════════════════════════════ -->
    <center>
        <StackPane styleClass="dashboard-content">
            <padding><Insets bottom="22.0" left="22.0" right="22.0" top="22.0"/></padding>

            <!-- ───────────────────────────────────────────────
                 PAGE 1 : LISTE DES QUIZ DISPONIBLES
            ─────────────────────────────────────────────── -->
            <VBox fx:id="quizListSection" spacing="18.0">
                <HBox spacing="18.0">
                    <VBox spacing="10.0" styleClass="hero-banner student-banner" HBox.hgrow="ALWAYS">
                        <Label styleClass="eyebrow" text="Évaluations disponibles"/>
                        <Label styleClass="hero-title small-hero"
                               text="Choisissez un quiz pour commencer." wrapText="true"/>
                        <Label fx:id="quizListSubtitleLabel" styleClass="hero-copy"
                               text="Les quiz ouverts à la passation sont affichés ci-dessous."
                               wrapText="true"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="8.0">
                        <Label fx:id="quizCountLabel" styleClass="stat-value" text="0"/>
                        <Label styleClass="stat-title" text="Quiz disponibles"/>
                    </VBox>
                </HBox>

                <ScrollPane fitToWidth="true" styleClass="form-scroll-pane" VBox.vgrow="ALWAYS">
                    <content>
                        <VBox fx:id="quizCardsContainer" spacing="14.0">
                            <padding><Insets bottom="8.0" right="4.0"/></padding>
                        </VBox>
                    </content>
                </ScrollPane>
                <Label fx:id="quizListMessageLabel"
                       styleClass="status-label neutral-status" text="" wrapText="true"/>
            </VBox>

            <!-- ───────────────────────────────────────────────
                 PAGE 2 : DÉTAIL DU QUIZ (avant de commencer)
            ─────────────────────────────────────────────── -->
            <VBox fx:id="quizDetailSection" managed="false" visible="false" spacing="18.0">
                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <Button onAction="#showQuizListPage"
                            styleClass="secondary-button compact-button" text="← Retour"/>
                    <Label styleClass="eyebrow" text="Détail du quiz"/>
                </HBox>

                <HBox spacing="18.0" VBox.vgrow="ALWAYS">
                    <!-- Fiche quiz -->
                    <VBox spacing="14.0" styleClass="panel-card" HBox.hgrow="ALWAYS">
                        <VBox spacing="8.0" styleClass="detail-hero-card">
                            <Label fx:id="detailQuizTitleLabel" styleClass="detail-hero-title"
                                   text="Titre du quiz" wrapText="true"/>
                            <Label fx:id="detailQuizTypeLabel" styleClass="detail-hero-meta"
                                   text="Type" wrapText="true"/>
                        </VBox>
                        <GridPane hgap="12.0" vgap="10.0">
                            <Label styleClass="detail-key" text="Description"
                                   GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                            <Label fx:id="detailQuizDescLabel"
                                   styleClass="detail-value detail-multiline wide-detail"
                                   text="-" wrapText="true"
                                   GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                            <Label styleClass="detail-key" text="Durée"
                                   GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                            <Label fx:id="detailQuizDureeLabel"
                                   styleClass="detail-value detail-multiline wide-detail"
                                   text="-" wrapText="true"
                                   GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                            <Label styleClass="detail-key" text="Questions"
                                   GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                            <Label fx:id="detailQuizNbQuestionsLabel"
                                   styleClass="detail-value detail-multiline wide-detail"
                                   text="-" wrapText="true"
                                   GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                            <Label styleClass="detail-key" text="Tentatives autorisées"
                                   GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                            <Label fx:id="detailQuizTentativesLabel"
                                   styleClass="detail-value detail-multiline wide-detail"
                                   text="-" wrapText="true"
                                   GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                            <Label styleClass="detail-key" text="Disponible jusqu'au"
                                   GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                            <Label fx:id="detailQuizDispoLabel"
                                   styleClass="detail-value detail-multiline wide-detail"
                                   text="-" wrapText="true"
                                   GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                            <Label styleClass="detail-key" text="Instructions"
                                   GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                            <Label fx:id="detailQuizInstructionsLabel"
                                   styleClass="detail-value detail-multiline wide-detail"
                                   text="-" wrapText="true"
                                   GridPane.columnIndex="1" GridPane.rowIndex="5"/>
                        </GridPane>
                        <Label fx:id="detailQuizMessageLabel"
                               styleClass="status-label neutral-status" text="" wrapText="true"/>
                        <Button fx:id="startQuizButton" onAction="#startQuiz"
                                styleClass="primary-button" text="🚀  Commencer le quiz"/>
                    </VBox>

                    <!-- Stats personnelles -->
                    <VBox spacing="14.0" styleClass="panel-card side-panel" prefWidth="240.0">
                        <Label styleClass="panel-title" text="Mes stats sur ce quiz"/>
                        <VBox styleClass="stat-card" spacing="6.0">
                            <Label styleClass="stat-title" text="Tentatives effectuées"/>
                            <Label fx:id="myTentativesLabel" styleClass="stat-value" text="0"/>
                        </VBox>
                        <VBox styleClass="stat-card" spacing="6.0">
                            <Label styleClass="stat-title" text="Meilleur score"/>
                            <Label fx:id="myBestScoreLabel" styleClass="stat-value" text="-"/>
                        </VBox>
                        <VBox styleClass="stat-card" spacing="6.0">
                            <Label styleClass="stat-title" text="Moyenne générale"/>
                            <Label fx:id="quizMoyenneLabel" styleClass="stat-value" text="-"/>
                        </VBox>
                    </VBox>
                </HBox>
            </VBox>

            <!-- ───────────────────────────────────────────────
                 PAGE 3 : PASSAGE DU QUIZ
            ─────────────────────────────────────────────── -->
            <VBox fx:id="quizPassageSection" managed="false" visible="false" spacing="18.0">

                <!-- Header : titre + progression + timer -->
                <HBox alignment="CENTER_LEFT" spacing="18.0"
                      styleClass="hero-banner student-banner">
                    <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                        <Label fx:id="passageQuizTitleLabel" styleClass="hero-title small-hero"
                               text="Quiz en cours" wrapText="true"/>
                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <Label fx:id="questionIndexLabel" styleClass="eyebrow"
                                   text="Question 1 / ?"/>
                            <ProgressBar fx:id="quizProgressBar" prefWidth="200.0" progress="0.0"
                                         styleClass="quiz-progress-bar"/>
                            <Label fx:id="progressPercentLabel" styleClass="sidebar-copy" text="0%"/>
                        </HBox>
                    </VBox>
                    <!-- Timer -->
                    <VBox alignment="CENTER" spacing="4.0" styleClass="stat-card" prefWidth="120.0">
                        <Label styleClass="stat-title" text="⏱ Temps restant"/>
                        <Label fx:id="timerLabel" styleClass="stat-value" text="--:--"/>
                    </VBox>
                </HBox>

                <HBox spacing="18.0" VBox.vgrow="ALWAYS">

                    <!-- Zone question + réponses -->
                    <VBox spacing="16.0" styleClass="panel-card"
                          HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">

                        <!-- Énoncé -->
                        <VBox spacing="8.0" styleClass="detail-hero-card">
                            <HBox alignment="CENTER_LEFT" spacing="10.0">
                                <Label fx:id="questionPointsLabel" styleClass="eyebrow" text="1 pt"/>
                                <Label fx:id="questionTypeLabel" styleClass="sidebar-copy"
                                       text="Choix multiple"/>
                            </HBox>
                            <Label fx:id="questionTexteLabel" styleClass="detail-hero-title"
                                   text="Énoncé de la question" wrapText="true"/>
                        </VBox>

                        <!-- Réponses : choix multiple / vrai-faux -->
                        <VBox fx:id="choixMultiplePanel" spacing="10.0">
                            <fx:define>
                                <ToggleGroup fx:id="reponseToggleGroup"/>
                            </fx:define>
                            <ScrollPane fitToWidth="true" styleClass="form-scroll-pane"
                                        prefHeight="220.0">
                                <content>
                                    <VBox fx:id="reponsesContainer" spacing="10.0">
                                        <padding><Insets right="4.0"/></padding>
                                    </VBox>
                                </content>
                            </ScrollPane>
                        </VBox>

                        <!-- Réponse texte libre -->
                        <VBox fx:id="texteLibrePanel" managed="false" visible="false" spacing="8.0">
                            <Label styleClass="detail-key" text="Votre réponse :"/>
                            <TextArea fx:id="texteLibreArea" prefHeight="130.0"
                                      promptText="Saisissez votre réponse ici…" wrapText="true"/>
                            <Label fx:id="texteLibreErrorLabel"
                                   styleClass="field-error-label" text="" wrapText="true"/>
                        </VBox>

                        <!-- Message erreur saisie -->
                        <Label fx:id="passageMessageLabel"
                               styleClass="field-error-label" text="" wrapText="true"/>

                        <!-- Navigation -->
                        <HBox alignment="CENTER_RIGHT" spacing="12.0">
                            <Button fx:id="previousQuestionButton"
                                    onAction="#previousQuestion"
                                    styleClass="secondary-button compact-button"
                                    text="← Précédent"
                                    managed="false" visible="false"/>
                            <HBox HBox.hgrow="ALWAYS"/>
                            <Button fx:id="nextQuestionButton"
                                    onAction="#nextQuestion"
                                    styleClass="primary-button compact-button"
                                    text="Suivant →"/>
                            <Button fx:id="submitQuizButton"
                                    onAction="#submitQuiz"
                                    styleClass="primary-button compact-button"
                                    text="✔  Soumettre"
                                    managed="false" visible="false"/>
                        </HBox>
                    </VBox>

                    <!-- Plan du quiz (navigation rapide) -->
                    <VBox spacing="10.0" styleClass="panel-card side-panel" prefWidth="190.0">
                        <Label styleClass="panel-title" text="Plan du quiz"/>
                        <ScrollPane fitToWidth="true" styleClass="form-scroll-pane"
                                    VBox.vgrow="ALWAYS">
                            <content>
                                <VBox fx:id="quizPlanContainer" spacing="6.0">
                                    <padding><Insets right="4.0"/></padding>
                                </VBox>
                            </content>
                        </ScrollPane>
                    </VBox>
                </HBox>
            </VBox>

            <!-- ───────────────────────────────────────────────
                 PAGE 4 : RÉSULTAT APRÈS SOUMISSION
            ─────────────────────────────────────────────── -->
            <VBox fx:id="quizResultatSection" managed="false" visible="false" spacing="18.0">

                <!-- Score hero -->
                <VBox alignment="CENTER" spacing="12.0"
                      styleClass="hero-banner student-banner">
                    <Label styleClass="eyebrow" text="Quiz terminé 🎉"/>
                    <Label fx:id="resultatQuizTitleLabel" styleClass="hero-title small-hero"
                           text="Résultat" wrapText="true"/>
                    <HBox alignment="CENTER" spacing="24.0">
                        <VBox alignment="CENTER" styleClass="stat-card">
                            <Label styleClass="stat-title" text="Score"/>
                            <Label fx:id="resultatScoreLabel" styleClass="stat-value" text="0%"/>
                        </VBox>
                        <VBox alignment="CENTER" styleClass="stat-card">
                            <Label styleClass="stat-title" text="Points"/>
                            <Label fx:id="resultatPointsLabel" styleClass="stat-value" text="0 / 0"/>
                        </VBox>
                        <VBox alignment="CENTER" styleClass="stat-card">
                            <Label styleClass="stat-title" text="Mention"/>
                            <Label fx:id="resultatMentionLabel" styleClass="stat-value" text="-"/>
                        </VBox>
                    </HBox>
                    <ProgressBar fx:id="resultatProgressBar" prefWidth="380.0" progress="0.0"
                                 styleClass="quiz-progress-bar"/>
                </VBox>

                <!-- Correction détaillée -->
                <VBox spacing="10.0" styleClass="panel-card" VBox.vgrow="ALWAYS">
                    <Label styleClass="panel-title" text="Correction détaillée"/>
                    <ScrollPane fitToWidth="true" styleClass="form-scroll-pane" VBox.vgrow="ALWAYS">
                        <content>
                            <VBox fx:id="correctionContainer" spacing="14.0">
                                <padding><Insets right="4.0"/></padding>
                            </VBox>
                        </content>
                    </ScrollPane>
                </VBox>

                <HBox spacing="12.0">
                    <Button onAction="#showQuizListPage"
                            styleClass="secondary-button compact-button"
                            text="← Retour aux quiz"/>
                    <Button onAction="#showMyResultsPage"
                            styleClass="primary-button compact-button"
                            text="🏆  Voir tous mes résultats"/>
                </HBox>
            </VBox>

            <!-- ───────────────────────────────────────────────
                 PAGE 5 : HISTORIQUE MES RÉSULTATS
            ─────────────────────────────────────────────── -->
            <VBox fx:id="myResultsSection" managed="false" visible="false" spacing="18.0">
                <HBox spacing="18.0">
                    <VBox spacing="10.0" styleClass="hero-banner student-banner" HBox.hgrow="ALWAYS">
                        <Label styleClass="eyebrow" text="Historique"/>
                        <Label styleClass="hero-title small-hero"
                               text="Mes résultats" wrapText="true"/>
                        <Label styleClass="hero-copy"
                               text="Retrouvez toutes vos tentatives et vos scores."
                               wrapText="true"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="8.0">
                        <Label fx:id="totalTentativesLabel" styleClass="stat-value" text="0"/>
                        <Label styleClass="stat-title" text="Tentatives totales"/>
                    </VBox>
                </HBox>

                <VBox spacing="10.0" styleClass="panel-card" VBox.vgrow="ALWAYS">
                    <Label styleClass="panel-title" text="Historique des passages"/>
                    <TableView fx:id="resultatsTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="resQuizTitleColumn"  prefWidth="220.0" text="Quiz"/>
                            <TableColumn fx:id="resScoreColumn"      prefWidth="100.0" text="Score"/>
                            <TableColumn fx:id="resPointsColumn"     prefWidth="130.0" text="Points"/>
                            <TableColumn fx:id="resDateColumn"       prefWidth="160.0" text="Date"/>
                            <TableColumn fx:id="resMentionColumn"    prefWidth="130.0" text="Mention"/>
                        </columns>
                    </TableView>
                </VBox>
                <Label fx:id="myResultsMessageLabel"
                       styleClass="status-label neutral-status" text="" wrapText="true"/>
            </VBox>

        </StackPane>
    </center>
</BorderPane>
