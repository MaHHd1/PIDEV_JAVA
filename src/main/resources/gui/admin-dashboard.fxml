<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.AdminDashboardController" styleClass="dashboard-shell">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="18.0" styleClass="topbar">
            <Label fx:id="welcomeLabel" styleClass="dashboard-title" text="Welcome back" />
            <HBox HBox.hgrow="ALWAYS" />
            <Button onAction="#refreshData" styleClass="secondary-button compact-button" text="Refresh" />
            <Button onAction="#logout" styleClass="danger-button compact-button" text="Logout" />
        </HBox>
    </top>
    <center>
        <VBox spacing="18.0" styleClass="dashboard-content">
            <padding>
                <Insets bottom="22.0" left="22.0" right="22.0" top="22.0" />
            </padding>
            <HBox spacing="14.0">
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <Label styleClass="stat-title" text="Total Users" />
                    <Label fx:id="totalUsersLabel" styleClass="stat-value" text="0" />
                </VBox>
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <Label styleClass="stat-title" text="Students" />
                    <Label fx:id="studentsCountLabel" styleClass="stat-value" text="0" />
                </VBox>
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <Label styleClass="stat-title" text="Teachers" />
                    <Label fx:id="teachersCountLabel" styleClass="stat-value" text="0" />
                </VBox>
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <Label styleClass="stat-title" text="Admins" />
                    <Label fx:id="adminsCountLabel" styleClass="stat-value" text="0" />
                </VBox>
            </HBox>
            <HBox spacing="18.0" VBox.vgrow="ALWAYS">
                <VBox spacing="12.0" styleClass="panel-card admin-main-panel" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                    <HBox spacing="10.0" alignment="CENTER_LEFT">
                        <Label styleClass="panel-title" text="User Registry" />
                        <HBox HBox.hgrow="ALWAYS" />
                        <Button onAction="#createUser" styleClass="primary-button compact-button" text="Add User" />
                        <TextField fx:id="searchField" promptText="Search by id, name, email, role..." styleClass="input-field inline-field" />
                        <ComboBox fx:id="roleFilterCombo" prefWidth="170.0" styleClass="inline-combo" />
                    </HBox>
                    <TableView fx:id="usersTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="idColumn" prefWidth="65.0" text="ID" />
                            <TableColumn fx:id="fullNameColumn" prefWidth="180.0" text="Full Name" />
                            <TableColumn fx:id="emailColumn" prefWidth="220.0" text="Email" />
                            <TableColumn fx:id="roleColumn" prefWidth="120.0" text="Role" />
                            <TableColumn fx:id="identifierColumn" prefWidth="150.0" text="Identifier" />
                            <TableColumn fx:id="statusColumn" prefWidth="100.0" text="Status" />
                            <TableColumn fx:id="lastLoginColumn" prefWidth="145.0" text="Last Login" />
                            <TableColumn fx:id="actionsColumn" prefWidth="250.0" text="Actions" />
                        </columns>
                    </TableView>
                </VBox>
                <VBox spacing="14.0" styleClass="panel-card details-panel" HBox.hgrow="NEVER">
                    <Label styleClass="panel-title" text="User Details" />
                    <GridPane hgap="10.0" vgap="10.0">
                        <Label styleClass="detail-key" text="Name" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                        <Label fx:id="detailNameLabel" styleClass="detail-value" text="-" GridPane.rowIndex="0" GridPane.columnIndex="1" />
                        <Label styleClass="detail-key" text="Email" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                        <Label fx:id="detailEmailLabel" styleClass="detail-value" text="-" GridPane.rowIndex="1" GridPane.columnIndex="1" />
                        <Label styleClass="detail-key" text="Role" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                        <Label fx:id="detailRoleLabel" styleClass="detail-value" text="-" GridPane.rowIndex="2" GridPane.columnIndex="1" />
                        <Label styleClass="detail-key" text="Identifier" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                        <Label fx:id="detailIdentifierLabel" styleClass="detail-value" text="-" GridPane.rowIndex="3" GridPane.columnIndex="1" />
                        <Label styleClass="detail-key" text="Status" GridPane.rowIndex="4" GridPane.columnIndex="0" />
                        <Label fx:id="detailStatusLabel" styleClass="detail-value" text="-" GridPane.rowIndex="4" GridPane.columnIndex="1" />
                        <Label styleClass="detail-key" text="Extra" GridPane.rowIndex="5" GridPane.columnIndex="0" />
                        <Label fx:id="detailInfoLabel" styleClass="detail-value" text="-" wrapText="true" GridPane.rowIndex="5" GridPane.columnIndex="1" />
                        <Label styleClass="detail-key" text="Created" GridPane.rowIndex="6" GridPane.columnIndex="0" />
                        <Label fx:id="detailCreatedLabel" styleClass="detail-value" text="-" GridPane.rowIndex="6" GridPane.columnIndex="1" />
                        <Label styleClass="detail-key" text="Last Login" GridPane.rowIndex="7" GridPane.columnIndex="0" />
                        <Label fx:id="detailLastLoginLabel" styleClass="detail-value" text="-" GridPane.rowIndex="7" GridPane.columnIndex="1" />
                    </GridPane>
                    <Label styleClass="panel-title" text="Activity Feed" />
                    <ListView fx:id="activityList" VBox.vgrow="ALWAYS" />
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>
