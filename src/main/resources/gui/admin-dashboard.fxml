                                        <TextField fx:id="contenuVideoField" promptText="Chemin local ou lien video" styleClass="input-field" HBox.hgrow="ALWAYS" />
                                        <Button onAction="#browseContenuVideoFile" styleClass="secondary-button compact-button" text="Choisir video" />
                                    </HBox>
                                    <Label fx:id="contenuVideoErrorLabel" styleClass="field-error-label" text="" wrapText="true" />
                                </VBox>
                                <VBox fx:id="contenuLienSection" managed="false" spacing="8.0" styleClass="type-card-section" visible="false">
                                    <Label styleClass="detail-section-title" text="Lien externe" />
                                    <TextField fx:id="contenuLienField" promptText="https://..." styleClass="input-field" />
                                    <Label fx:id="contenuLienErrorLabel" styleClass="field-error-label" text="" wrapText="true" />
                                </VBox>
                                <VBox fx:id="contenuQuizSection" managed="false" spacing="8.0" styleClass="type-card-section" visible="false">
                                    <Label styleClass="detail-section-title" text="Reference Quiz" />
                                    <TextField fx:id="contenuQuizField" promptText="Ex: QUIZ-JAVA-01" styleClass="input-field" />
                                    <Label fx:id="contenuQuizErrorLabel" styleClass="field-error-label" text="" wrapText="true" />
                                </VBox>
                                <VBox fx:id="contenuTexteSection" managed="false" spacing="6.0" styleClass="type-card-section" visible="false">
                                    <Label styleClass="detail-section-title" text="Contenu texte" />
                                    <Label styleClass="dashboard-subsection" text="Quand le type texte est choisi, la zone Description devient obligatoire et sert de contenu textuel." wrapText="true" />
                                </VBox>
                                <HBox alignment="CENTER_RIGHT" spacing="12.0">
                                    <Button onAction="#cancelContenuForm" styleClass="secondary-button compact-button" text="Retour a la liste" />
                                    <Button onAction="#saveContenu" styleClass="primary-button compact-button" text="Enregistrer le contenu" />
                                </HBox>
                            </VBox>
                        </content>
                    </ScrollPane>
                </VBox>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
