<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.AdminDashboardController" styleClass="dashboard-shell">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="18.0" styleClass="topbar">
            <Label fx:id="welcomeLabel" styleClass="dashboard-title" text="Welcome back" />
            <HBox HBox.hgrow="ALWAYS" />
            <Button onAction="#refreshData" styleClass="secondary-button compact-button" text="Refresh" />
            <Button onAction="#logout" styleClass="danger-button compact-button" text="Logout" />
        </HBox>
    </top>
    <center>
        <VBox spacing="18.0" styleClass="dashboard-content">
            <padding>
                <Insets bottom="22.0" left="22.0" right="22.0" top="22.0" />
            </padding>
            <HBox spacing="14.0">
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <Label styleClass="stat-title" text="Total Users" />
                    <Label fx:id="totalUsersLabel" styleClass="stat-value" text="0" />
                </VBox>
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <Label styleClass="stat-title" text="Students" />
                    <Label fx:id="studentsCountLabel" styleClass="stat-value" text="0" />
                </VBox>
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <Label styleClass="stat-title" text="Teachers" />
                    <Label fx:id="teachersCountLabel" styleClass="stat-value" text="0" />
                </VBox>
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <Label styleClass="stat-title" text="Admins" />
                    <Label fx:id="adminsCountLabel" styleClass="stat-value" text="0" />
                </VBox>
            </HBox>
            <HBox spacing="18.0" VBox.vgrow="ALWAYS">
                <VBox spacing="10.0" styleClass="panel-card" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                    <Label styleClass="panel-title" text="User Registry" />
                    <TableView fx:id="usersTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="idColumn" prefWidth="90.0" text="ID" />
                            <TableColumn fx:id="fullNameColumn" prefWidth="220.0" text="Full Name" />
                            <TableColumn fx:id="emailColumn" prefWidth="280.0" text="Email" />
                            <TableColumn fx:id="roleColumn" prefWidth="140.0" text="Role" />
                        </columns>
                    </TableView>
                </VBox>
                <VBox spacing="10.0" styleClass="panel-card side-panel" HBox.hgrow="NEVER">
                    <Label styleClass="panel-title" text="Control Feed" />
                    <ListView fx:id="activityList" VBox.vgrow="ALWAYS" />
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>
