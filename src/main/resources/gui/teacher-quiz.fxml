<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="gui.QuizController"
            styleClass="dashboard-shell teacher-shell">

    <!-- ═══ SIDEBAR ═══════════════════════════════════════════════ -->
    <left>
        <VBox spacing="16.0" styleClass="sidebar">
            <padding><Insets bottom="20.0" left="18.0" right="18.0" top="20.0"/></padding>
            <Label styleClass="sidebar-brand" text="Quiz Manager"/>
            <Label styleClass="sidebar-copy"
                   text="Créez et gérez vos quiz, questions et réponses." wrapText="true"/>
            <Button maxWidth="1.7976931348623157E308" onAction="#showQuizListPage"
                    styleClass="sidebar-button" text="📋  Mes quiz"/>
            <Button maxWidth="1.7976931348623157E308" onAction="#showQuizCreateForm"
                    styleClass="sidebar-button" text="➕  Nouveau quiz"/>
            <VBox VBox.vgrow="ALWAYS"/>
            <Label styleClass="sidebar-foot" text="Gestion pédagogique · Campus Access" wrapText="true"/>
        </VBox>
    </left>

    <!-- ═══ TOPBAR ════════════════════════════════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="18.0" styleClass="topbar profile-topbar">
            <VBox spacing="4.0">
                <Label fx:id="sectionTitleLabel" styleClass="dashboard-title" text="Gestion des Quiz"/>
                <Label fx:id="sectionSubtitleLabel" styleClass="dashboard-subtitle"
                       text="Créez, modifiez et organisez vos quiz et leurs questions."/>
            </VBox>
            <HBox HBox.hgrow="ALWAYS"/>
            <HBox alignment="CENTER_RIGHT" spacing="10.0" styleClass="profile-chip">
                <VBox alignment="CENTER_RIGHT" spacing="2.0">
                    <Label fx:id="currentUserNameLabel" styleClass="profile-name" text="Enseignant"/>
                    <Label fx:id="currentUserRoleLabel" styleClass="profile-role" text="enseignant"/>
                </VBox>
                <MenuButton fx:id="profileMenuButton" styleClass="profile-menu-button" text="EN">
                    <items>
                        <MenuItem onAction="#handleLogout" text="Déconnexion"/>
                    </items>
                </MenuButton>
            </HBox>
        </HBox>
    </top>

    <!-- ═══ CENTRE ════════════════════════════════════════════════ -->
    <center>
        <StackPane styleClass="dashboard-content">
            <padding><Insets bottom="22.0" left="22.0" right="22.0" top="22.0"/></padding>

            <!-- ── PAGE 1 : LISTE DES QUIZ ──────────────────────── -->
            <VBox fx:id="quizListSection" spacing="18.0">
                <HBox spacing="18.0">
                    <VBox spacing="10.0" styleClass="hero-banner teacher-banner" HBox.hgrow="ALWAYS">
                        <Label styleClass="eyebrow" text="Mes quiz"/>
                        <Label styleClass="hero-title small-hero"
                               text="Supervisez tous vos quiz et accédez aux questions." wrapText="true"/>
                        <Label fx:id="quizListSubtitleLabel" styleClass="hero-copy"
                               text="Sélectionnez un quiz pour le modifier ou gérer ses questions." wrapText="true"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="10.0">
                        <Button onAction="#showQuizCreateForm"
                                styleClass="primary-button compact-button" text="➕  Nouveau quiz"/>
                        <Label fx:id="quizListMessageLabel"
                               styleClass="status-label neutral-status" text="" wrapText="true"/>
                    </VBox>
                </HBox>

                <HBox spacing="18.0" VBox.vgrow="ALWAYS">
                    <VBox spacing="10.0" styleClass="panel-card modules-list-panel"
                          HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                        <Label styleClass="panel-title" text="Liste des quiz"/>
                        <TableView fx:id="quizTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="quizTitreColumn"     prefWidth="220.0" text="Titre"/>
                                <TableColumn fx:id="quizTypeColumn"      prefWidth="120.0" text="Type"/>
                                <TableColumn fx:id="quizDureeColumn"     prefWidth="90.0"  text="Durée (min)"/>
                                <TableColumn fx:id="quizQuestionsColumn" prefWidth="100.0" text="Cours"/>
                                <TableColumn fx:id="quizDispoColumn"     prefWidth="180.0" text="Disponible jusqu'au"/>
                                <TableColumn fx:id="quizActionsColumn"   prefWidth="260.0" text="Actions"/>
                            </columns>
                        </TableView>
                    </VBox>

                    <!-- Panneau détail quiz -->
                    <VBox fx:id="quizDetailsPanel" managed="false" visible="false"
                          spacing="14.0" styleClass="panel-card modules-detail-panel">
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Label styleClass="panel-title" text="Fiche du quiz"/>
                            <HBox HBox.hgrow="ALWAYS"/>
                            <Button onAction="#closeQuizDetails" styleClass="detail-close-button" text="X"/>
                        </HBox>
                        <VBox spacing="8.0" styleClass="detail-hero-card">
                            <Label fx:id="detailQuizTitleLabel" styleClass="detail-hero-title"
                                   text="Aucun quiz sélectionné" wrapText="true"/>
                            <Label fx:id="detailQuizMetaLabel" styleClass="detail-hero-meta"
                                   text="Sélectionnez un quiz dans la liste." wrapText="true"/>
                        </VBox>
                        <GridPane hgap="12.0" vgap="8.0">
                            <Label styleClass="detail-key" text="Type"          GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                            <Label fx:id="detailQuizTypeLabel" styleClass="detail-value detail-multiline wide-detail" text="-" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                            <Label styleClass="detail-key" text="Durée"         GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                            <Label fx:id="detailQuizDureeLabel" styleClass="detail-value detail-multiline wide-detail" text="-" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                            <Label styleClass="detail-key" text="Tentatives"    GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                            <Label fx:id="detailQuizTentativesLabel" styleClass="detail-value detail-multiline wide-detail" text="-" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                            <Label styleClass="detail-key" text="Correction"    GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                            <Label fx:id="detailQuizCorrectionLabel" styleClass="detail-value detail-multiline wide-detail" text="-" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                            <Label styleClass="detail-key" text="Disponibilité" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                            <Label fx:id="detailQuizDispoLabel" styleClass="detail-value detail-multiline wide-detail" text="-" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                            <Label styleClass="detail-key" text="Description"   GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                            <Label fx:id="detailQuizDescLabel" styleClass="detail-value detail-multiline wide-detail" text="-" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
                        </GridPane>
                        <HBox spacing="8.0">
                            <Button onAction="#editSelectedQuiz"
                                    styleClass="secondary-button compact-button" text="✏  Modifier"/>
                            <Button onAction="#manageQuestionsOfSelectedQuiz"
                                    styleClass="primary-button compact-button" text="❓  Questions"/>
                            <Button onAction="#deleteSelectedQuiz"
                                    styleClass="danger-button compact-button" text="🗑  Supprimer"/>
                        </HBox>
                    </VBox>
                </HBox>
            </VBox>

            <!-- ── PAGE 2 : FORMULAIRE QUIZ (redesigné) ─────────── -->
            <VBox fx:id="quizFormSection" managed="false" visible="false" spacing="20.0">

                <!-- Hero banner -->
                <VBox spacing="6.0" styleClass="hero-banner create-banner">
                    <padding><Insets bottom="20.0" left="24.0" right="24.0" top="20.0"/></padding>
                    <Label styleClass="eyebrow" text="Édition quiz"/>
                    <Label fx:id="quizFormTitleLabel" styleClass="hero-title small-hero"
                           text="Nouveau quiz" wrapText="true"/>
                    <Label styleClass="hero-copy"
                           text="Renseignez toutes les informations. Les champs marqués * sont obligatoires."
                           wrapText="true"/>
                </VBox>

                <ScrollPane fitToWidth="true" styleClass="form-scroll-pane" VBox.vgrow="ALWAYS">
                    <content>
                        <VBox spacing="20.0">
                            <padding><Insets bottom="10.0" right="4.0"/></padding>

                            <!-- ── BLOC 1 : Informations générales ── -->
                            <VBox spacing="16.0" styleClass="panel-card">
                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <Label text="📝" style="-fx-font-size:18px;"/>
                                    <Label text="Informations générales" styleClass="panel-title"/>
                                </HBox>

                                <!-- Titre -->
                                <VBox spacing="6.0">
                                    <Label styleClass="detail-key" text="Titre du quiz *"/>
                                    <TextField fx:id="quizTitreField"
                                               promptText="Ex : Quiz Java POO - Chapitre 3"
                                               styleClass="input-field"/>
                                    <Label fx:id="quizTitreErrorLabel"
                                           styleClass="field-error-label" text="" wrapText="true"/>
                                </VBox>

                                <!-- Type + Correction sur la même ligne -->
                                <HBox spacing="16.0">
                                    <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                        <Label styleClass="detail-key" text="Type de quiz *"/>
                                        <ComboBox fx:id="quizTypeCombo" maxWidth="1.7976931348623157E308"
                                                  promptText="Choisissez un type"/>
                                        <Label fx:id="quizTypeErrorLabel"
                                               styleClass="field-error-label" text="" wrapText="true"/>
                                    </VBox>
                                    <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                        <Label styleClass="detail-key" text="Correction affichée *"/>
                                        <ComboBox fx:id="quizCorrectionApresCombo" maxWidth="1.7976931348623157E308"
                                                  promptText="Quand afficher la correction ?"/>
                                        <Label fx:id="quizCorrectionErrorLabel"
                                               styleClass="field-error-label" text="" wrapText="true"/>
                                    </VBox>
                                </HBox>

                                <!-- Description -->
                                <VBox spacing="6.0">
                                    <Label styleClass="detail-key" text="Description"/>
                                    <TextArea fx:id="quizDescriptionArea" prefRowCount="3"
                                              promptText="Décrivez brièvement ce quiz..."
                                              wrapText="true"/>
                                    <Label fx:id="quizDescriptionErrorLabel"
                                           styleClass="field-error-label" text="" wrapText="true"/>
                                </VBox>

                                <!-- Instructions -->
                                <VBox spacing="6.0">
                                    <Label styleClass="detail-key" text="Instructions pour l'étudiant"/>
                                    <TextArea fx:id="quizInstructionsArea" prefRowCount="3"
                                              promptText="Consignes affichées avant le démarrage du quiz..."
                                              wrapText="true"/>
                                    <Label fx:id="quizInstructionsErrorLabel"
                                           styleClass="field-error-label" text="" wrapText="true"/>
                                </VBox>
                            </VBox>

                            <!-- ── BLOC 2 : Paramètres ── -->
                            <VBox spacing="16.0" styleClass="panel-card">
                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <Label text="⚙️" style="-fx-font-size:18px;"/>
                                    <Label text="Paramètres du quiz" styleClass="panel-title"/>
                                </HBox>

                                <HBox spacing="16.0">
                                    <!-- Durée -->
                                    <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                        <Label styleClass="detail-key" text="Durée (minutes) *"/>
                                        <Spinner fx:id="quizDureeSpinner"
                                                 min="1" max="480" initialValue="30" editable="true"
                                                 maxWidth="1.7976931348623157E308"/>
                                        <Label fx:id="quizDureeErrorLabel"
                                               styleClass="field-error-label" text="" wrapText="true"/>
                                    </VBox>
                                    <!-- Tentatives -->
                                    <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                        <Label styleClass="detail-key" text="Tentatives maximum *"/>
                                        <Spinner fx:id="quizTentativesSpinner"
                                                 min="1" max="99" initialValue="1" editable="true"
                                                 maxWidth="1.7976931348623157E308"/>
                                        <Label fx:id="quizTentativesErrorLabel"
                                               styleClass="field-error-label" text="" wrapText="true"/>
                                    </VBox>
                                    <!-- ID Cours -->
                                    <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                        <Label styleClass="detail-key" text="ID du cours (optionnel)"/>
                                        <TextField fx:id="quizIdCoursField"
                                                   promptText="Ex : 12" styleClass="input-field"/>
                                        <Label fx:id="quizIdCoursErrorLabel"
                                               styleClass="field-error-label" text="" wrapText="true"/>
                                    </VBox>
                                </HBox>
                            </VBox>

                            <!-- ── BLOC 3 : Disponibilité (dates obligatoires) ── -->
                            <VBox spacing="16.0" styleClass="panel-card">
                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <Label text="📅" style="-fx-font-size:18px;"/>
                                    <Label text="Période de disponibilité" styleClass="panel-title"/>
                                </HBox>
                                <Label styleClass="dashboard-subsection"
                                       text="Les deux dates sont obligatoires. La date de fin doit être postérieure à la date de début."
                                       wrapText="true"/>

                                <HBox spacing="16.0">
                                    <!-- Date début -->
                                    <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                        <Label styleClass="detail-key" text="Date d'ouverture *"/>
                                        <DatePicker fx:id="quizDateDebutPicker"
                                                    promptText="jj/mm/aaaa"
                                                    maxWidth="1.7976931348623157E308"/>
                                        <Label fx:id="quizDateDebutErrorLabel"
                                               styleClass="field-error-label" text="" wrapText="true"/>
                                    </VBox>

                                    <!-- Séparateur visuel -->
                                    <VBox alignment="CENTER" style="-fx-padding: 24 0 0 0;">
                                        <Label text="→"
                                               style="-fx-font-size:20px; -fx-text-fill:#94a3b8; -fx-font-weight:900;"/>
                                    </VBox>

                                    <!-- Date fin -->
                                    <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                        <Label styleClass="detail-key" text="Date de clôture *"/>
                                        <DatePicker fx:id="quizDateFinPicker"
                                                    promptText="jj/mm/aaaa"
                                                    maxWidth="1.7976931348623157E308"/>
                                        <Label fx:id="quizDateFinErrorLabel"
                                               styleClass="field-error-label" text="" wrapText="true"/>
                                    </VBox>
                                </HBox>

                                <!-- Résumé période (affiché dynamiquement via controller) -->
                                <HBox spacing="10.0" alignment="CENTER_LEFT"
                                      style="-fx-background-color:#f0fdf4; -fx-background-radius:12; -fx-padding:12;">
                                    <Label text="ℹ️" style="-fx-font-size:14px;"/>
                                    <Label fx:id="quizDateRangeInfoLabel"
                                           text="Sélectionnez les deux dates pour voir la période."
                                           styleClass="dashboard-subsection" wrapText="true"
                                           HBox.hgrow="ALWAYS"/>
                                </HBox>
                            </VBox>

                            <!-- ── Barre d'action ── -->
                            <HBox alignment="CENTER_RIGHT" spacing="12.0">
                                <Label fx:id="quizFormStatusLabel"
                                       styleClass="status-label neutral-status"
                                       text="" HBox.hgrow="ALWAYS" wrapText="true"/>
                                <Button onAction="#cancelQuizForm"
                                        styleClass="secondary-button compact-button"
                                        text="← Retour à la liste"/>
                                <Button onAction="#saveQuiz"
                                        styleClass="primary-button compact-button"
                                        text="💾  Enregistrer le quiz"/>
                            </HBox>
                        </VBox>
                    </content>
                </ScrollPane>
            </VBox>

            <!-- ── PAGE 3 : QUESTIONS ───────────────────────────── -->
            <VBox fx:id="questionsSection" managed="false" visible="false" spacing="18.0">
                <HBox spacing="18.0">
                    <VBox spacing="10.0" styleClass="hero-banner teacher-banner" HBox.hgrow="ALWAYS">
                        <Label styleClass="eyebrow" text="Questions du quiz"/>
                        <Label fx:id="questionsSectionTitleLabel" styleClass="hero-title small-hero"
                               text="Questions" wrapText="true"/>
                        <Label fx:id="questionsSectionSubtitleLabel" styleClass="hero-copy"
                               text="Ajoutez, modifiez ou supprimez les questions de ce quiz." wrapText="true"/>
                    </VBox>
                    <VBox alignment="CENTER_RIGHT" spacing="10.0">
                        <Button onAction="#showQuizListPage"
                                styleClass="secondary-button compact-button" text="← Retour quiz"/>
                        <Button onAction="#showQuestionCreateForm"
                                styleClass="primary-button compact-button" text="➕  Nouvelle question"/>
                        <Label fx:id="questionsMessageLabel"
                               styleClass="status-label neutral-status" text="" wrapText="true"/>
                    </VBox>
                </HBox>

                <HBox spacing="18.0" VBox.vgrow="ALWAYS">
                    <VBox spacing="10.0" styleClass="panel-card modules-list-panel"
                          HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                        <Label styleClass="panel-title" text="Liste des questions"/>
                        <TableView fx:id="questionsTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="qOrdreColumn"    prefWidth="60.0"  text="#"/>
                                <TableColumn fx:id="qTexteColumn"    prefWidth="280.0" text="Énoncé"/>
                                <TableColumn fx:id="qTypeColumn"     prefWidth="130.0" text="Type"/>
                                <TableColumn fx:id="qPointsColumn"   prefWidth="80.0"  text="Points"/>
                                <TableColumn fx:id="qReponsesColumn" prefWidth="90.0"  text="Réponses"/>
                                <TableColumn fx:id="qActionsColumn"  prefWidth="180.0" text="Actions"/>
                            </columns>
                        </TableView>
                    </VBox>

                    <VBox fx:id="questionDetailsPanel" managed="false" visible="false"
                          spacing="14.0" styleClass="panel-card modules-detail-panel">
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Label styleClass="panel-title" text="Fiche question"/>
                            <HBox HBox.hgrow="ALWAYS"/>
                            <Button onAction="#closeQuestionDetails" styleClass="detail-close-button" text="X"/>
                        </HBox>
                        <VBox spacing="8.0" styleClass="detail-hero-card">
                            <Label fx:id="detailQuestionTexteLabel" styleClass="detail-hero-title"
                                   text="Aucune question sélectionnée" wrapText="true"/>
                            <Label fx:id="detailQuestionMetaLabel" styleClass="detail-hero-meta"
                                   text="Type · Points" wrapText="true"/>
                        </VBox>
                        <Label styleClass="panel-title" text="Réponses"/>
                        <ScrollPane fitToWidth="true" styleClass="form-scroll-pane" prefHeight="180.0">
                            <content>
                                <VBox fx:id="detailReponsesContainer" spacing="8.0">
                                    <padding><Insets right="4.0"/></padding>
                                </VBox>
                            </content>
                        </ScrollPane>
                        <Label fx:id="detailQuestionExplicationLabel"
                               styleClass="sidebar-copy" text="" wrapText="true"/>
                        <HBox spacing="8.0">
                            <Button onAction="#editSelectedQuestion"
                                    styleClass="secondary-button compact-button" text="✏  Modifier"/>
                            <Button onAction="#manageReponsesOfSelectedQuestion"
                                    styleClass="primary-button compact-button" text="💬  Réponses"/>
                            <Button onAction="#deleteSelectedQuestion"
                                    styleClass="danger-button compact-button" text="🗑  Supprimer"/>
                        </HBox>
                    </VBox>
                </HBox>
            </VBox>

            <!-- ── PAGE 4 : FORMULAIRE QUESTION ────────────────── -->
            <VBox fx:id="questionFormSection" managed="false" visible="false" spacing="20.0">
                <VBox spacing="6.0" styleClass="hero-banner create-banner">
                    <padding><Insets bottom="20.0" left="24.0" right="24.0" top="20.0"/></padding>
                    <Label styleClass="eyebrow" text="Édition question"/>
                    <Label fx:id="questionFormTitleLabel" styleClass="hero-title small-hero"
                           text="Nouvelle question" wrapText="true"/>
                    <Label styleClass="hero-copy"
                           text="Rédigez la question puis ajoutez ses réponses." wrapText="true"/>
                </VBox>

                <ScrollPane fitToWidth="true" styleClass="form-scroll-pane" VBox.vgrow="ALWAYS">
                    <content>
                        <VBox spacing="20.0">
                            <padding><Insets bottom="10.0" right="4.0"/></padding>

                            <VBox spacing="16.0" styleClass="panel-card">
                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <Label text="❓" style="-fx-font-size:18px;"/>
                                    <Label text="Contenu de la question" styleClass="panel-title"/>
                                </HBox>

                                <VBox spacing="6.0">
                                    <Label styleClass="detail-key" text="Énoncé *"/>
                                    <TextArea fx:id="questionTexteArea" prefRowCount="4"
                                              promptText="Rédigez l'énoncé de la question..."
                                              wrapText="true"/>
                                    <Label fx:id="questionTexteErrorLabel"
                                           styleClass="field-error-label" text="" wrapText="true"/>
                                </VBox>

                                <HBox spacing="16.0">
                                    <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                        <Label styleClass="detail-key" text="Type de question *"/>
                                        <ComboBox fx:id="questionTypeCombo" maxWidth="1.7976931348623157E308"
                                                  promptText="Choisissez un type"/>
                                        <Label fx:id="questionTypeErrorLabel"
                                               styleClass="field-error-label" text="" wrapText="true"/>
                                    </VBox>
                                    <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                        <Label styleClass="detail-key" text="Points *"/>
                                        <Spinner fx:id="questionPointsSpinner"
                                                 min="1" max="100" initialValue="1" editable="true"
                                                 maxWidth="1.7976931348623157E308"/>
                                        <Label fx:id="questionPointsErrorLabel"
                                               styleClass="field-error-label" text="" wrapText="true"/>
                                    </VBox>
                                    <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                        <Label styleClass="detail-key" text="Ordre d'affichage"/>
                                        <Spinner fx:id="questionOrdreSpinner"
                                                 min="1" max="999" initialValue="1" editable="true"
                                                 maxWidth="1.7976931348623157E308"/>
                                    </VBox>
                                </HBox>

                                <VBox spacing="6.0">
                                    <Label styleClass="detail-key" text="Explication (affichée après correction)"/>
                                    <TextArea fx:id="questionExplicationArea" prefRowCount="3"
                                              promptText="Optionnel : explication affichée après la correction..."
                                              wrapText="true"/>
                                    <Label fx:id="questionExplicationErrorLabel"
                                           styleClass="field-error-label" text="" wrapText="true"/>
                                </VBox>
                            </VBox>

                            <HBox alignment="CENTER_RIGHT" spacing="12.0">
                                <Label fx:id="questionFormStatusLabel"
                                       styleClass="status-label neutral-status"
                                       text="" HBox.hgrow="ALWAYS" wrapText="true"/>
                                <Button onAction="#cancelQuestionForm"
                                        styleClass="secondary-button compact-button" text="← Retour questions"/>
                                <Button onAction="#saveQuestion"
                                        styleClass="primary-button compact-button" text="💾  Enregistrer"/>
                            </HBox>
                        </VBox>
                    </content>
                </ScrollPane>
            </VBox>

            <!-- ── PAGE 5 : RÉPONSES ────────────────────────────── -->
            <VBox fx:id="reponsesSection" managed="false" visible="false" spacing="18.0">
                <HBox spacing="18.0">
                    <VBox spacing="10.0" styleClass="hero-banner teacher-banner" HBox.hgrow="ALWAYS">
                        <Label styleClass="eyebrow" text="Réponses"/>
                        <Label fx:id="reponsesSectionTitleLabel" styleClass="hero-title small-hero"
                               text="Réponses de la question" wrapText="true"/>
                        <Label fx:id="reponsesSectionSubtitleLabel" styleClass="hero-copy"
                               text="Ajoutez les réponses et marquez la ou les correctes." wrapText="true"/>
                    </VBox>
                    <VBox alignment="CENTER_RIGHT" spacing="10.0">
                        <Button onAction="#backToQuestionsFromReponses"
                                styleClass="secondary-button compact-button" text="← Retour questions"/>
                        <Button onAction="#showReponseCreateForm"
                                styleClass="primary-button compact-button" text="➕  Nouvelle réponse"/>
                        <Label fx:id="reponsesMessageLabel"
                               styleClass="status-label neutral-status" text="" wrapText="true"/>
                    </VBox>
                </HBox>

                <HBox spacing="18.0" VBox.vgrow="ALWAYS">
                    <VBox spacing="10.0" styleClass="panel-card modules-list-panel"
                          HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                        <Label styleClass="panel-title" text="Liste des réponses"/>
                        <TableView fx:id="reponsesTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="rOrdreColumn"    prefWidth="60.0"  text="#"/>
                                <TableColumn fx:id="rTexteColumn"    prefWidth="300.0" text="Texte réponse"/>
                                <TableColumn fx:id="rCorrecteColumn" prefWidth="100.0" text="Correcte"/>
                                <TableColumn fx:id="rFeedbackColumn" prefWidth="160.0" text="Feedback"/>
                                <TableColumn fx:id="rActionsColumn"  prefWidth="160.0" text="Actions"/>
                            </columns>
                        </TableView>
                    </VBox>

                    <!-- Formulaire réponse inline -->
                    <VBox fx:id="reponseFormPanel" managed="false" visible="false"
                          spacing="14.0" styleClass="panel-card modules-detail-panel">
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Label fx:id="reponseFormTitleLabel" styleClass="panel-title" text="Nouvelle réponse"/>
                            <HBox HBox.hgrow="ALWAYS"/>
                            <Button onAction="#closeReponseForm" styleClass="detail-close-button" text="X"/>
                        </HBox>

                        <VBox spacing="6.0">
                            <Label styleClass="detail-key" text="Texte de la réponse *"/>
                            <TextArea fx:id="reponseTexteArea" prefRowCount="4"
                                      promptText="Saisissez le texte de la réponse..." wrapText="true"/>
                            <Label fx:id="reponseTexteErrorLabel"
                                   styleClass="field-error-label" text="" wrapText="true"/>
                        </VBox>

                        <CheckBox fx:id="reponseCorrecteCheck"
                                  text="✅  Cette réponse est correcte"
                                  style="-fx-font-weight:700; -fx-text-fill:#16a34a;"/>

                        <HBox spacing="16.0">
                            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                <Label styleClass="detail-key" text="Ordre d'affichage"/>
                                <Spinner fx:id="reponseOrdreSpinner" min="1" max="99" initialValue="1"
                                         editable="true" maxWidth="1.7976931348623157E308"/>
                                <Label fx:id="reponseOrdreErrorLabel"
                                       styleClass="field-error-label" text="" wrapText="true"/>
                            </VBox>
                        </HBox>

                        <VBox spacing="6.0">
                            <Label styleClass="detail-key" text="Feedback spécifique (optionnel)"/>
                            <TextArea fx:id="reponseFeedbackArea" prefRowCount="3"
                                      promptText="Message affiché si cette réponse est choisie..."
                                      wrapText="true"/>
                            <Label fx:id="reponseFeedbackErrorLabel"
                                   styleClass="field-error-label" text="" wrapText="true"/>
                        </VBox>

                        <VBox spacing="6.0">
                            <Label styleClass="detail-key" text="URL média (optionnel)"/>
                            <TextField fx:id="reponseMediaUrlField"
                                       promptText="https://..." styleClass="input-field"/>
                        </VBox>

                        <Label fx:id="reponseFormStatusLabel"
                               styleClass="status-label neutral-status" text="" wrapText="true"/>

                        <HBox spacing="10.0">
                            <Button onAction="#closeReponseForm"
                                    styleClass="secondary-button compact-button" text="Annuler"/>
                            <Button onAction="#saveReponse"
                                    styleClass="primary-button compact-button" text="💾  Enregistrer"/>
                        </HBox>
                    </VBox>
                </HBox>
            </VBox>

        </StackPane>
    </center>
</BorderPane>
