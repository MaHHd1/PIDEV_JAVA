<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.StudentOverviewController" spacing="18.0">
    <VBox spacing="8.0">
        <styleClass>
            <String fx:value="hero-banner" />
            <String fx:value="student-banner" />
        </styleClass>
        <Label styleClass="eyebrow" text="Vue d'ensemble" />
        <Label fx:id="welcomeLabel" text="Bienvenue" wrapText="true">
            <styleClass>
                <String fx:value="hero-title" />
                <String fx:value="small-hero" />
            </styleClass>
        </Label>
    </VBox>
    <HBox spacing="14.0">
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label styleClass="stat-title" text="Mes cours" />
            <Label fx:id="enrolledCoursesCountLabel" styleClass="stat-value" text="0" />
        </VBox>
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label styleClass="stat-title" text="Catalogue" />
            <Label fx:id="availableCoursesCountLabel" styleClass="stat-value" text="0" />
        </VBox>
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label styleClass="stat-title" text="Contenus" />
            <Label fx:id="accessibleContentsCountLabel" styleClass="stat-value" text="0" />
        </VBox>
    </HBox>
    <HBox spacing="18.0" VBox.vgrow="ALWAYS">
        <VBox spacing="10.0" styleClass="panel-card" HBox.hgrow="ALWAYS">
            <Label styleClass="panel-title" text="Profil etudiant" />
            <TableView fx:id="profileTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="profileFieldColumn" prefWidth="210.0" text="Champ" />
                    <TableColumn fx:id="profileValueColumn" prefWidth="360.0" text="Valeur" />
                </columns>
            </TableView>
        </VBox>
        <VBox spacing="10.0" styleClass="panel-card" HBox.hgrow="ALWAYS">
            <Label styleClass="panel-title" text="Priorites" />
            <TableView fx:id="focusTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="focusTitleColumn" prefWidth="180.0" text="Sujet" />
                    <TableColumn fx:id="focusDescriptionColumn" prefWidth="300.0" text="Detail" />
                </columns>
            </TableView>
        </VBox>
    </HBox>
</VBox>
