<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.ForgotPasswordController" styleClass="content-shell auth-shell">
    <center>
        <HBox alignment="CENTER" maxWidth="1020.0" spacing="22.0" styleClass="auth-page-shell" BorderPane.alignment="CENTER">
            <children>
                <VBox spacing="14.0" styleClass="auth-hero-panel" HBox.hgrow="ALWAYS">
                    <Label styleClass="auth-kicker" text="Password Recovery" />
                    <Label styleClass="auth-hero-title" text="Reset your password" wrapText="true" />
                    <Label styleClass="auth-hero-copy" text="Modifiez votre mot de passe depuis une interface claire, avec le meme langage visuel que le reste de l'application." wrapText="true" />
                    <VBox spacing="10.0" styleClass="auth-feature-list">
                        <Label styleClass="auth-feature-item" text="Changement de mot de passe direct" />
                        <Label styleClass="auth-feature-item" text="Meme template que les autres ecrans" />
                        <Label styleClass="auth-feature-item" text="Retour rapide vers la connexion" />
                    </VBox>
                </VBox>
                <VBox alignment="CENTER_LEFT" maxWidth="420.0" spacing="16.0" styleClass="auth-form-card" HBox.hgrow="ALWAYS">
                    <padding>
                        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
                    </padding>
                    <Label styleClass="section-subtitle" text="Password Recovery" />
                    <Label styleClass="card-title" text="Reset your password" />
                    <Label styleClass="card-subtitle" text="For now you can reset directly with email and a new password. Token generation is still kept in the database for later implementation." wrapText="true" />
                    <TextField fx:id="emailField" promptText="Email address" styleClass="input-field" />
                    <PasswordField fx:id="newPasswordField" promptText="New password" styleClass="input-field" />
                    <PasswordField fx:id="confirmPasswordField" promptText="Confirm new password" styleClass="input-field" />
                    <Button maxWidth="1.7976931348623157E308" onAction="#handleResetRequest" styleClass="primary-button" text="Change password" />
                    <Button maxWidth="1.7976931348623157E308" onAction="#goBack" styleClass="secondary-button" text="Back to login" />
                    <Label fx:id="feedbackLabel" styleClass="status-label" wrapText="true" />
                </VBox>
            </children>
            <padding>
                <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
            </padding>
        </HBox>
    </center>
</BorderPane>
