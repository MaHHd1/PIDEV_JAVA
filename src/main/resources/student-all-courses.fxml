<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.StudentAllCoursesController" spacing="18.0">
    <VBox spacing="8.0">
        <styleClass>
            <String fx:value="hero-banner" />
            <String fx:value="student-banner" />
        </styleClass>
        <Label styleClass="eyebrow" text="Catalogue" />
        <Label text="Tous les cours">
            <styleClass>
                <String fx:value="hero-title" />
                <String fx:value="small-hero" />
            </styleClass>
        </Label>
        <Label styleClass="content-copy" text="Explorez le catalogue et inscrivez-vous directement." wrapText="true" />
    </VBox>
    <VBox spacing="10.0" styleClass="panel-card" VBox.vgrow="ALWAYS">
        <TableView fx:id="coursesTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="codeColumn" prefWidth="120.0" text="Code" />
                <TableColumn fx:id="titleColumn" prefWidth="220.0" text="Titre" />
                <TableColumn fx:id="moduleColumn" prefWidth="170.0" text="Module" />
                <TableColumn fx:id="levelColumn" prefWidth="110.0" text="Niveau" />
                <TableColumn fx:id="statusColumn" prefWidth="110.0" text="Statut" />
                <TableColumn fx:id="contentsColumn" prefWidth="90.0" text="Contenus" />
                <TableColumn fx:id="actionColumn" prefWidth="130.0" text="Action" />
            </columns>
        </TableView>
    </VBox>
</VBox>
