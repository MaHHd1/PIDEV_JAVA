<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      spacing="16.0">
    <styleClass>
        <String fx:value="sidebar" />
        <String fx:value="admin-sidebar" />
    </styleClass>
    <padding>
        <Insets bottom="20.0" left="18.0" right="18.0" top="20.0" />
    </padding>
    <Label styleClass="sidebar-brand" text="Admin Hub" />
    <Label styleClass="sidebar-copy" text="Navigate your user management workspace." wrapText="true" />
    <Button maxWidth="1.7976931348623157E308" onAction="#showUsersPage" styleClass="sidebar-button" text="User Info" />
    <Button maxWidth="1.7976931348623157E308" onAction="#showStatsPage" styleClass="sidebar-button" text="Statistics" />
    <Button maxWidth="1.7976931348623157E308" onAction="#showCreatePage" styleClass="sidebar-button" text="Add User" />
    <Button maxWidth="1.7976931348623157E308" onAction="#showModulesPage" styleClass="sidebar-button" text="Modules" />
    <Button maxWidth="1.7976931348623157E308" onAction="#showCourseStatisticsPage" styleClass="sidebar-button" text="Statistiques cours" />
    <Button maxWidth="1.7976931348623157E308" onAction="#showEvenementsPage" styleClass="sidebar-button" text="Evenements" />
    <Button maxWidth="1.7976931348623157E308" onAction="#showForumPage" styleClass="sidebar-button" text="Forums" />
    <Button maxWidth="1.7976931348623157E308" onAction="#showMessagePage" styleClass="sidebar-button" text="Messages" />
    <VBox VBox.vgrow="ALWAYS" />
    <Label styleClass="sidebar-foot" text="Espace administrateur" wrapText="true" />
    <Button maxWidth="1.7976931348623157E308" onAction="#handleProfileLogout" styleClass="secondary-button" text="Deconnexion" />
</VBox>
