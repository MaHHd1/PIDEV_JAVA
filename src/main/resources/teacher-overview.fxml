<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.TeacherOverviewController" spacing="18.0">
    <VBox spacing="8.0" styleClass="hero-banner,teacher-banner">
        <Label styleClass="eyebrow" text="Vue d'ensemble" />
        <Label fx:id="welcomeLabel" styleClass="hero-title small-hero" text="Bienvenue" wrapText="true" />
    </VBox>
    <HBox spacing="14.0">
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label styleClass="stat-title" text="Mes cours" />
            <Label fx:id="coursesCountLabel" styleClass="stat-value" text="0" />
        </VBox>
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label styleClass="stat-title" text="Mes etudiants" />
            <Label fx:id="studentsCountLabel" styleClass="stat-value" text="0" />
        </VBox>
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label styleClass="stat-title" text="Cours publies" />
            <Label fx:id="publishedCoursesLabel" styleClass="stat-value" text="0" />
        </VBox>
    </HBox>
    <HBox spacing="18.0" VBox.vgrow="ALWAYS">
        <VBox spacing="10.0" styleClass="panel-card" HBox.hgrow="ALWAYS">
            <Label styleClass="panel-title" text="Profil enseignant" />
            <TableView fx:id="profileTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="profileFieldColumn" prefWidth="210.0" text="Champ" />
                    <TableColumn fx:id="profileValueColumn" prefWidth="360.0" text="Valeur" />
                </columns>
            </TableView>
        </VBox>
        <VBox spacing="10.0" styleClass="panel-card" HBox.hgrow="ALWAYS">
            <Label styleClass="panel-title" text="Points d'attention" />
            <TableView fx:id="focusTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="focusTitleColumn" prefWidth="180.0" text="Sujet" />
                    <TableColumn fx:id="focusDescriptionColumn" prefWidth="300.0" text="Detail" />
                </columns>
            </TableView>
        </VBox>
    </HBox>
</VBox>
