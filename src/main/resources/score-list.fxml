<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Pagination?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.gui.ScoreListController"
            styleClass="content-shell">
    <top>
        <VBox spacing="18.0">
            <children>
                <VBox styleClass="content-header teacher-content-header">
                    <Label styleClass="content-title" text="Mes corrections" />
                    <Label styleClass="content-copy" text="Corrigez les soumissions en attente et suivez rapidement les notes deja publiees." wrapText="true" />
                </VBox>
                <HBox alignment="CENTER_LEFT" styleClass="filter-bar">
                    <TextField fx:id="searchField" promptText="Rechercher une soumission ou un statut" styleClass="input-field" HBox.hgrow="ALWAYS" />
                    <ComboBox fx:id="sortByComboBox" prefWidth="170.0" styleClass="input-combo" />
                    <ComboBox fx:id="sortOrderComboBox" prefWidth="150.0" styleClass="input-combo" />
                    <ComboBox fx:id="pageSizeComboBox" prefWidth="110.0" styleClass="input-combo" />
                </HBox>
            </children>
            <padding>
                <Insets bottom="16.0" left="4.0" right="4.0" top="4.0" />
            </padding>
        </VBox>
    </top>
    <center>
        <VBox styleClass="section-card">
            <Label styleClass="section-subtitle" text="Corrections enseignant" />
            <TableView fx:id="correctionTableView" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="idColumn" text="ID" />
                    <TableColumn fx:id="evaluationColumn" text="Evaluation" />
                    <TableColumn fx:id="studentColumn" text="Etudiant" />
                    <TableColumn fx:id="noteColumn" text="Note" />
                    <TableColumn fx:id="pourcentageColumn" text="Pourcentage" />
                    <TableColumn fx:id="statutColumn" text="Statut" />
                    <TableColumn fx:id="dateColumn" text="Date" />
                    <TableColumn fx:id="actionsColumn" text="Actions" />
                </columns>
            </TableView>
        </VBox>
    </center>
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="12.0" styleClass="filter-bar">
            <Label fx:id="paginationSummaryLabel" styleClass="muted-label" text="0 correction" />
            <Pagination fx:id="pagination" maxPageIndicatorCount="5" pageCount="1" />
        </HBox>
    </bottom>
</BorderPane>
