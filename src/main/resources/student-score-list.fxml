<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Pagination?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="gui.StudentScoreListController"
            prefHeight="720.0"
            prefWidth="1100.0">
    <top>
        <VBox spacing="16.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="16.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="12.0">
                <Label style="-fx-font-size: 22px; -fx-font-weight: bold;" text="Mes Notes" />
                <HBox HBox.hgrow="ALWAYS" />
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="12.0">
                <Label text="Recherche" />
                <TextField fx:id="searchField" promptText="Titre d'évaluation, type..." HBox.hgrow="ALWAYS" />
                <Label text="Trier par" />
                <ComboBox fx:id="sortByComboBox" prefWidth="160.0" />
                <Label text="Ordre" />
                <ComboBox fx:id="sortOrderComboBox" prefWidth="140.0" />
                <Label text="Par page" />
                <ComboBox fx:id="pageSizeComboBox" prefWidth="100.0" />
            </HBox>
        </VBox>
    </top>
    <center>
        <TableView fx:id="notesTableView" BorderPane.alignment="CENTER">
            <columns>
                <TableColumn fx:id="idColumn" text="ID" prefWidth="60.0" />
                <TableColumn fx:id="evaluationColumn" text="Évaluation" prefWidth="250.0" />
                <TableColumn fx:id="typeColumn" text="Type" prefWidth="120.0" />
                <TableColumn fx:id="noteColumn" text="Note" prefWidth="100.0" />
                <TableColumn fx:id="pourcentageColumn" text="Pourcentage" prefWidth="100.0" />
                <TableColumn fx:id="statutColumn" text="Statut" prefWidth="120.0" />
                <TableColumn fx:id="dateColumn" text="Date correction" prefWidth="120.0" />
                <TableColumn fx:id="actionsColumn" text="Actions" prefWidth="100.0" />
            </columns>
        </TableView>
    </center>
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="12.0">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="16.0" />
            </padding>
            <Label fx:id="paginationSummaryLabel" text="0 note" />
            <Pagination fx:id="pagination" maxPageIndicatorCount="5" pageCount="1" />
        </HBox>
    </bottom>
</BorderPane>

