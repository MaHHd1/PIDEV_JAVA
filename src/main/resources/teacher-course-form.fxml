<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.TeacherCourseFormController" spacing="18.0">
    <VBox spacing="8.0">
        <styleClass>
            <String fx:value="hero-banner" />
            <String fx:value="create-banner" />
        </styleClass>
        <Label styleClass="eyebrow" text="Nouveau cours" />
        <Label fx:id="titleLabel" text="Creer un cours">
            <styleClass>
                <String fx:value="hero-title" />
                <String fx:value="small-hero" />
            </styleClass>
        </Label>
        <Label styleClass="content-copy" text="Remplissez les informations du cours dans une interface uniforme avec le reste des dashboards." wrapText="true" />
    </VBox>
    <VBox spacing="14.0" styleClass="panel-card">
        <GridPane hgap="14.0" vgap="14.0">
            <Label styleClass="detail-key" text="Module" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <ComboBox fx:id="moduleCombo" prefWidth="220.0" styleClass="input-combo" GridPane.columnIndex="1" GridPane.rowIndex="0" />
            <Label styleClass="detail-key" text="Code" GridPane.columnIndex="2" GridPane.rowIndex="0" />
            <TextField fx:id="codeField" styleClass="input-field" GridPane.columnIndex="3" GridPane.rowIndex="0" />
            <Label styleClass="detail-key" text="Titre" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <TextField fx:id="titleField" styleClass="input-field" GridPane.columnIndex="1" GridPane.columnSpan="3" GridPane.rowIndex="1" />
            <Label styleClass="detail-key" text="Description" GridPane.columnIndex="0" GridPane.rowIndex="2" />
            <TextArea fx:id="descriptionArea" prefRowCount="4" styleClass="input-area" GridPane.columnIndex="1" GridPane.columnSpan="3" GridPane.rowIndex="2" />
            <Label styleClass="detail-key" text="Niveau" GridPane.columnIndex="0" GridPane.rowIndex="3" />
            <TextField fx:id="levelField" styleClass="input-field" GridPane.columnIndex="1" GridPane.rowIndex="3" />
            <Label styleClass="detail-key" text="Credits" GridPane.columnIndex="2" GridPane.rowIndex="3" />
            <TextField fx:id="creditsField" styleClass="input-field" GridPane.columnIndex="3" GridPane.rowIndex="3" />
            <Label styleClass="detail-key" text="Langue" GridPane.columnIndex="0" GridPane.rowIndex="4" />
            <TextField fx:id="languageField" styleClass="input-field" GridPane.columnIndex="1" GridPane.rowIndex="4" />
            <Label styleClass="detail-key" text="Statut" GridPane.columnIndex="2" GridPane.rowIndex="4" />
            <ComboBox fx:id="statusCombo" prefWidth="180.0" styleClass="input-combo" GridPane.columnIndex="3" GridPane.rowIndex="4" />
            <Label styleClass="detail-key" text="Date debut" GridPane.columnIndex="0" GridPane.rowIndex="5" />
            <DatePicker fx:id="startDatePicker" styleClass="input-date-picker" GridPane.columnIndex="1" GridPane.rowIndex="5" />
            <Label styleClass="detail-key" text="Date fin" GridPane.columnIndex="2" GridPane.rowIndex="5" />
            <DatePicker fx:id="endDatePicker" styleClass="input-date-picker" GridPane.columnIndex="3" GridPane.rowIndex="5" />
            <Label styleClass="detail-key" text="Image" GridPane.columnIndex="0" GridPane.rowIndex="6" />
            <TextField fx:id="imageField" styleClass="input-field" GridPane.columnIndex="1" GridPane.columnSpan="3" GridPane.rowIndex="6" />
            <Label styleClass="detail-key" text="Prerequis" GridPane.columnIndex="0" GridPane.rowIndex="7" />
            <TextArea fx:id="prerequisArea" prefRowCount="3" styleClass="input-area" GridPane.columnIndex="1" GridPane.columnSpan="3" GridPane.rowIndex="7" />
        </GridPane>
        <HBox alignment="CENTER_RIGHT" spacing="12.0">
            <Label fx:id="feedbackLabel" text="" HBox.hgrow="ALWAYS" wrapText="true">
                <styleClass>
                    <String fx:value="status-label" />
                    <String fx:value="neutral-status" />
                </styleClass>
            </Label>
            <Button onAction="#handleBack" styleClass="secondary-button compact-button" text="Retour" />
            <Button onAction="#handleSave" styleClass="primary-button compact-button" text="Enregistrer" />
        </HBox>
    </VBox>
</VBox>
