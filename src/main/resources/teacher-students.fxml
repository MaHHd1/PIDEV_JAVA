<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.TeacherStudentsController" spacing="18.0">
    <HBox alignment="CENTER_LEFT" spacing="12.0">
        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
            <styleClass>
                <String fx:value="hero-banner" />
                <String fx:value="teacher-banner" />
            </styleClass>
            <Label styleClass="eyebrow" text="Etudiants" />
            <Label text="Mes etudiants">
                <styleClass>
                    <String fx:value="hero-title" />
                    <String fx:value="small-hero" />
                </styleClass>
            </Label>
            <Label styleClass="content-copy" text="Filtrez les etudiants par cours enseigne." wrapText="true" />
        </VBox>
        <ComboBox fx:id="courseFilterCombo" prefWidth="260.0" styleClass="input-combo" />
    </HBox>
    <VBox spacing="10.0" styleClass="panel-card" VBox.vgrow="ALWAYS">
        <TableView fx:id="studentsTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="matriculeColumn" prefWidth="130.0" text="Matricule" />
                <TableColumn fx:id="nameColumn" prefWidth="220.0" text="Nom complet" />
                <TableColumn fx:id="emailColumn" prefWidth="220.0" text="Email" />
                <TableColumn fx:id="levelColumn" prefWidth="130.0" text="Niveau" />
                <TableColumn fx:id="specialiteColumn" prefWidth="180.0" text="Specialisation" />
            </columns>
        </TableView>
    </VBox>
</VBox>
