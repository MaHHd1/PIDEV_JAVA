<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="gui.StudentQuizController"
            styleClass="dashboard-shell student-shell">

    <!-- ═══ SIDEBAR ═══════════════════════════════════════════════ -->
    <left>
        <VBox spacing="16.0" styleClass="sidebar">
            <padding><Insets bottom="20.0" left="18.0" right="18.0" top="20.0"/></padding>
            <Label styleClass="sidebar-brand" text="Quiz Étudiant"/>
            <Label styleClass="sidebar-copy"
                   text="Passez vos quiz et consultez vos résultats." wrapText="true"/>
            <Button maxWidth="1.7976931348623157E308" onAction="#showQuizListPage"
                    styleClass="sidebar-button" text="📋  Quiz disponibles"/>
            <Button maxWidth="1.7976931348623157E308" onAction="#showMesResultats"
                    styleClass="sidebar-button" text="🏆  Mes résultats"/>
            <VBox VBox.vgrow="ALWAYS"/>
            <Label styleClass="sidebar-foot" text="Espace étudiant · Campus Access" wrapText="true"/>
        </VBox>
    </left>

    <!-- ═══ TOPBAR ════════════════════════════════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="18.0" styleClass="topbar profile-topbar">
            <VBox spacing="4.0">
                <Label fx:id="sectionTitleLabel" styleClass="dashboard-title" text="Mes Quiz"/>
                <Label fx:id="sectionSubtitleLabel" styleClass="dashboard-subtitle"
                       text="Consultez et passez les quiz disponibles."/>
            </VBox>
            <HBox HBox.hgrow="ALWAYS"/>
            <HBox alignment="CENTER_RIGHT" spacing="10.0" styleClass="profile-chip">
                <VBox alignment="CENTER_RIGHT" spacing="2.0">
                    <Label fx:id="currentUserNameLabel" styleClass="profile-name" text="Étudiant"/>
                    <Label fx:id="currentUserRoleLabel" styleClass="profile-role" text="étudiant"/>
                </VBox>
                <MenuButton fx:id="profileMenuButton" styleClass="profile-menu-button" text="ET">
                    <items>
                        <MenuItem onAction="#handleLogout" text="Déconnexion"/>
                    </items>
                </MenuButton>
            </HBox>
        </HBox>
    </top>

    <!-- ═══ CENTRE ════════════════════════════════════════════════ -->
    <center>
        <StackPane styleClass="dashboard-content">
            <padding><Insets bottom="22.0" left="22.0" right="22.0" top="22.0"/></padding>

            <!-- ══════════════════════════════════════════════════
                 PAGE 1 : LISTE DES QUIZ DISPONIBLES
                 ══════════════════════════════════════════════════ -->
            <VBox fx:id="quizListSection" spacing="18.0">
                <HBox spacing="18.0">
                    <VBox spacing="10.0" styleClass="hero-banner teacher-banner" HBox.hgrow="ALWAYS">
                        <Label styleClass="eyebrow" text="Quiz disponibles"/>
                        <Label styleClass="hero-title small-hero"
                               text="Choisissez un quiz et commencez !" wrapText="true"/>
                        <Label styleClass="hero-copy"
                               text="Sélectionnez un quiz dans la liste pour voir les détails et démarrer."
                               wrapText="true"/>
                    </VBox>
                    <VBox alignment="CENTER">
                        <Label fx:id="quizListMessageLabel"
                               styleClass="status-label neutral-status" text="" wrapText="true"/>
                    </VBox>
                </HBox>

                <HBox spacing="18.0" VBox.vgrow="ALWAYS">
                    <!-- Table des quiz -->
                    <VBox spacing="10.0" styleClass="panel-card modules-list-panel"
                          HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                        <Label styleClass="panel-title" text="Quiz disponibles"/>

                        <!-- Barre de recherche + filtres -->
                        <HBox spacing="10.0" alignment="CENTER_LEFT">
                            <TextField fx:id="searchField"
                                       promptText="&#128269;  Rechercher un quiz..."
                                       styleClass="input-field"
                                       HBox.hgrow="ALWAYS"
                                       maxWidth="1.7976931348623157E308"/>
                            <ComboBox fx:id="filterTypeCombo"
                                      promptText="Type"
                                      prefWidth="130.0"/>
                            <ComboBox fx:id="filterDureeCombo"
                                      promptText="Dur&#233;e"
                                      prefWidth="130.0"/>
                            <Button onAction="#resetFilters"
                                    styleClass="secondary-button compact-button"
                                    text="&#10006;  R&#233;initialiser"/>
                        </HBox>
                        <Label fx:id="filterResultLabel"
                               styleClass="dashboard-subsection" text="" wrapText="true"/>

                        <TableView fx:id="quizTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="quizTitreColumn"  prefWidth="220.0" text="Titre"/>
                                <TableColumn fx:id="quizTypeColumn"   prefWidth="120.0" text="Type"/>
                                <TableColumn fx:id="quizDureeColumn"  prefWidth="100.0" text="Durée (min)"/>
                                <TableColumn fx:id="quizDispoColumn"  prefWidth="180.0" text="Disponible jusqu'au"/>
                                <TableColumn fx:id="quizActionsColumn" prefWidth="140.0" text="Action"/>
                            </columns>
                        </TableView>
                    </VBox>

                    <!-- Panneau détail / démarrage -->
                    <VBox fx:id="quizInfoPanel" managed="false" visible="false"
                          spacing="16.0" styleClass="panel-card modules-detail-panel">
                        <Label styleClass="panel-title" text="Détails du quiz"/>
                        <VBox spacing="8.0" styleClass="detail-hero-card">
                            <Label fx:id="detailQuizTitleLabel" styleClass="detail-hero-title"
                                   text="Titre du quiz" wrapText="true"/>
                        </VBox>
                        <VBox spacing="8.0">
                            <HBox spacing="10.0">
                                <Label styleClass="detail-key" text="Type :" minWidth="100.0"/>
                                <Label fx:id="detailQuizTypeLabel" styleClass="detail-value" text="-" wrapText="true"/>
                            </HBox>
                            <HBox spacing="10.0">
                                <Label styleClass="detail-key" text="Durée :" minWidth="100.0"/>
                                <Label fx:id="detailQuizDureeLabel" styleClass="detail-value" text="-"/>
                            </HBox>
                            <HBox spacing="10.0">
                                <Label styleClass="detail-key" text="Tentatives :" minWidth="100.0"/>
                                <Label fx:id="detailQuizTentativesLabel" styleClass="detail-value" text="-"/>
                            </HBox>
                        </VBox>
                        <Separator opacity="0.3"/>
                        <VBox spacing="6.0">
                            <Label styleClass="detail-key" text="Description"/>
                            <Label fx:id="detailQuizDescLabel" styleClass="sidebar-copy"
                                   text="" wrapText="true"/>
                        </VBox>
                        <VBox spacing="6.0">
                            <Label styleClass="detail-key" text="Instructions"/>
                            <Label fx:id="detailQuizInstructionsLabel" styleClass="sidebar-copy"
                                   text="" wrapText="true"/>
                        </VBox>
                        <Separator opacity="0.3"/>
                        <Label fx:id="detailQuizScoreLabel"
                               styleClass="status-label success-status"
                               text="" wrapText="true"/>
                        <Button fx:id="startQuizButton" maxWidth="1.7976931348623157E308"
                                onAction="#startQuiz"
                                styleClass="primary-button"
                                text="▶  Commencer le quiz"
                                style="-fx-font-size:14px; -fx-padding: 12 0;"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- ══════════════════════════════════════════════════
                 PAGE 2 : PASSAGE DU QUIZ
                 ══════════════════════════════════════════════════ -->
            <VBox fx:id="quizPassageSection" managed="false" visible="false" spacing="18.0">

                <!-- Header quiz en cours -->
                <HBox alignment="CENTER_LEFT" spacing="18.0"
                      styleClass="hero-banner teacher-banner">
                    <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                        <Label styleClass="eyebrow" text="Quiz en cours"/>
                        <Label fx:id="passageQuizTitleLabel"
                               styleClass="hero-title small-hero" text="" wrapText="true"/>
                        <HBox spacing="12.0" alignment="CENTER_LEFT">
                            <Label fx:id="questionCounterLabel"
                                   styleClass="dashboard-subtitle" text="Question 1 / ?"/>
                            <ProgressBar fx:id="progressBar" progress="0"
                                         prefWidth="180.0"
                                         style="-fx-accent:#3b82f6;"/>
                            <Label fx:id="progressLabel" styleClass="dashboard-subtitle" text=""/>
                        </HBox>
                    </VBox>
                    <!-- Timer -->
                    <VBox alignment="CENTER" spacing="4.0"
                          style="-fx-background-color:#f0fdf4; -fx-background-radius:14;
                                 -fx-padding: 14 22; -fx-border-color:#bbf7d0;
                                 -fx-border-radius:14; -fx-border-width:2;">
                        <Label text="⏱ Temps restant" styleClass="detail-key"
                               style="-fx-font-size:11px;"/>
                        <Label fx:id="timerLabel"
                               text="--:--"
                               style="-fx-font-size:26px; -fx-font-weight:900; -fx-text-fill:#16a34a;"/>
                    </VBox>
                    <Button onAction="#abandonQuiz"
                            styleClass="danger-button compact-button"
                            text="✖  Abandonner"/>
                </HBox>

                <!-- Corps question -->
                <ScrollPane fitToWidth="true" styleClass="form-scroll-pane" VBox.vgrow="ALWAYS">
                    <content>
                        <VBox spacing="18.0">
                            <padding><Insets bottom="10.0" right="4.0"/></padding>

                            <!-- Énoncé -->
                            <VBox spacing="10.0" styleClass="panel-card">
                                <Label styleClass="detail-key"
                                       text="Énoncé de la question" style="-fx-font-size:11px;"/>
                                <Label fx:id="questionTexteLabel"
                                       styleClass="hero-title small-hero"
                                       text="" wrapText="true"
                                       style="-fx-font-size:16px;"/>
                                <Label fx:id="questionTypeHintLabel"
                                       styleClass="status-label neutral-status"
                                       text="" wrapText="true"/>
                                <Label fx:id="questionErrorLabel"
                                       styleClass="field-error-label" text="" wrapText="true"/>
                            </VBox>

                            <!-- ── VRAI / FAUX ── -->
                            <VBox fx:id="vraiFauxPanel" managed="false" visible="false"
                                  spacing="14.0" styleClass="panel-card">
                                <Label styleClass="panel-title" text="Sélectionnez votre réponse"/>
                                <Separator opacity="0.3"/>
                                <HBox spacing="32.0" alignment="CENTER_LEFT" style="-fx-padding: 4 0 0 0;">
                                    <RadioButton fx:id="vraiFauxVraiRadio"
                                                 text="  ✅  Vrai"
                                                 style="-fx-font-size:15px; -fx-font-weight:600;"
                                                 styleClass="quiz-option">
                                        <toggleGroup><ToggleGroup fx:id="vraiFauxGroup"/></toggleGroup>
                                    </RadioButton>
                                    <RadioButton fx:id="vraiFauxFauxRadio"
                                                 text="  ❌  Faux"
                                                 toggleGroup="$vraiFauxGroup"
                                                 style="-fx-font-size:15px; -fx-font-weight:600;"
                                                 styleClass="quiz-option"/>
                                </HBox>
                            </VBox>

                            <!-- ── CHOIX UNIQUE ── -->
                            <VBox fx:id="choixUniquePanel" managed="false" visible="false"
                                  spacing="14.0" styleClass="panel-card">
                                <Label styleClass="panel-title" text="Choisissez une réponse"/>
                                <Separator opacity="0.3"/>
                                <VBox fx:id="choixUniqueContainer" spacing="10.0"/>
                            </VBox>

                            <!-- ── CHOIX MULTIPLE ── -->
                            <VBox fx:id="choixMultiplePanel" managed="false" visible="false"
                                  spacing="14.0" styleClass="panel-card">
                                <Label styleClass="panel-title" text="Cochez toutes les bonnes réponses"/>
                                <Separator opacity="0.3"/>
                                <VBox fx:id="choixMultipleContainer" spacing="10.0"/>
                            </VBox>

                            <!-- ── TEXTE LIBRE ── -->
                            <VBox fx:id="texteLibrePanel" managed="false" visible="false"
                                  spacing="14.0" styleClass="panel-card">
                                <Label styleClass="panel-title" text="Votre réponse"/>
                                <Separator opacity="0.3"/>
                                <TextArea fx:id="texteLibreArea" prefRowCount="5"
                                          promptText="Rédigez votre réponse ici..."
                                          wrapText="true"/>
                            </VBox>

                            <!-- ── Navigation ── -->
                            <HBox alignment="CENTER" spacing="16.0" style="-fx-padding: 4 0 8 0;">
                                <Button fx:id="prevButton" onAction="#prevQuestion"
                                        styleClass="secondary-button"
                                        text="◀  Précédente"
                                        style="-fx-min-width:140px;"/>
                                <Button fx:id="nextButton" onAction="#nextQuestion"
                                        styleClass="primary-button"
                                        text="Suivante  ▶"
                                        style="-fx-min-width:140px;"/>
                                <Button fx:id="submitButton" managed="false" visible="false"
                                        onAction="#submitQuiz"
                                        styleClass="primary-button"
                                        text="✔  Soumettre le quiz"
                                        style="-fx-min-width:200px; -fx-background-color:#16a34a;"/>
                            </HBox>
                        </VBox>
                    </content>
                </ScrollPane>
            </VBox>

            <!-- ══════════════════════════════════════════════════
                 PAGE 3 : RÉSULTATS
                 ══════════════════════════════════════════════════ -->
            <VBox fx:id="resultatsSection" managed="false" visible="false" spacing="18.0">

                <!-- Score principal -->
                <VBox alignment="CENTER" spacing="12.0"
                      styleClass="hero-banner create-banner"
                      style="-fx-padding: 32 24;">
                    <Label styleClass="eyebrow" text="Quiz terminé !"/>
                    <Label fx:id="resultatScoreLabel"
                           text="--"
                           style="-fx-font-size:56px; -fx-font-weight:900; -fx-text-fill:#1e40af;"/>
                    <Label fx:id="resultatPointsLabel"
                           styleClass="dashboard-subtitle" text="" style="-fx-font-size:16px;"/>
                    <Label fx:id="resultatMsgLabel"
                           styleClass="hero-copy"
                           text="" wrapText="true" style="-fx-font-size:16px; -fx-font-weight:700;"/>
                    <Label fx:id="resultatDateLabel"
                           styleClass="sidebar-copy" text=""/>
                </VBox>

                <!-- Détail question par question -->
                <ScrollPane fitToWidth="true" styleClass="form-scroll-pane" VBox.vgrow="ALWAYS">
                    <content>
                        <VBox spacing="14.0">
                            <padding><Insets bottom="10.0" right="4.0"/></padding>
                            <Label styleClass="panel-title" text="Détail par question"/>
                            <VBox fx:id="resultatDetailsContainer" spacing="12.0"/>
                        </VBox>
                    </content>
                </ScrollPane>

                <!-- Bouton retour -->
                <HBox alignment="CENTER" style="-fx-padding: 0 0 8 0;">
                    <Button onAction="#retourListeQuiz"
                            styleClass="primary-button"
                            text="◀  Retour à la liste des quiz"
                            style="-fx-min-width:220px;"/>
                </HBox>
            </VBox>

        </StackPane>
    </center>
</BorderPane>
