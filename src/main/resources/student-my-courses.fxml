<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.StudentMyCoursesController" spacing="18.0">
    <HBox alignment="CENTER_LEFT" spacing="12.0">
        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
            <Label styleClass="dashboard-title" text="Mes cours" />
            <Label fx:id="messageLabel" styleClass="dashboard-subtitle" text="Vos inscriptions actuelles." wrapText="true" />
        </VBox>
        <Button onAction="#handleOpenCatalog" styleClass="primary-button compact-button" text="Tous les cours" />
    </HBox>
    <HBox spacing="18.0" VBox.vgrow="ALWAYS">
        <VBox spacing="10.0" styleClass="panel-card" HBox.hgrow="ALWAYS">
            <TableView fx:id="coursesTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="codeColumn" prefWidth="120.0" text="Code" />
                    <TableColumn fx:id="titleColumn" prefWidth="220.0" text="Titre" />
                    <TableColumn fx:id="moduleColumn" prefWidth="170.0" text="Module" />
                    <TableColumn fx:id="levelColumn" prefWidth="110.0" text="Niveau" />
                    <TableColumn fx:id="statusColumn" prefWidth="110.0" text="Statut" />
                    <TableColumn fx:id="contentsColumn" prefWidth="90.0" text="Contenus" />
                </columns>
            </TableView>
        </VBox>
        <VBox spacing="12.0" styleClass="panel-card modules-detail-panel">
            <Label fx:id="detailTitleLabel" styleClass="panel-title" text="Aucun cours selectionne" />
            <Label fx:id="detailCodeLabel" styleClass="detail-value" text="-" wrapText="true" />
            <Label fx:id="detailModuleLabel" styleClass="detail-value" text="-" wrapText="true" />
            <Label fx:id="detailDescriptionLabel" styleClass="detail-value detail-multiline wide-detail" text="-" wrapText="true" />
            <Label fx:id="detailMetaLabel" styleClass="dashboard-subsection" text="-" wrapText="true" />
        </VBox>
    </HBox>
</VBox>
