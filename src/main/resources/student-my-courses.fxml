<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.StudentMyCoursesController" spacing="18.0">
    <HBox alignment="CENTER_LEFT" spacing="12.0">
        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
            <styleClass>
                <String fx:value="hero-banner" />
                <String fx:value="student-banner" />
            </styleClass>
            <Label styleClass="eyebrow" text="Cours" />
            <Label text="Mes cours">
                <styleClass>
                    <String fx:value="hero-title" />
                    <String fx:value="small-hero" />
                </styleClass>
            </Label>
            <Label fx:id="messageLabel" styleClass="content-copy" text="Vos inscriptions actuelles. Cliquez sur un cours pour ouvrir son espace." wrapText="true" />
        </VBox>
        <Button onAction="#handleOpenCatalog" styleClass="primary-button compact-button" text="Tous les cours" />
    </HBox>
    <VBox spacing="10.0" styleClass="panel-card" VBox.vgrow="ALWAYS">
        <TableView fx:id="coursesTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="codeColumn" prefWidth="140.0" text="Code" />
                <TableColumn fx:id="titleColumn" prefWidth="280.0" text="Titre" />
                <TableColumn fx:id="moduleColumn" prefWidth="210.0" text="Module" />
                <TableColumn fx:id="levelColumn" prefWidth="120.0" text="Niveau" />
                <TableColumn fx:id="statusColumn" prefWidth="120.0" text="Statut" />
                <TableColumn fx:id="contentsColumn" prefWidth="95.0" text="Contenus" />
            </columns>
        </TableView>
    </VBox>
</VBox>
